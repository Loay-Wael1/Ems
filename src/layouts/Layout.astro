---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Easy Fit Alexandria | Alexandria's 1st EMS Studio", 
  description = "تمارين EMS في إسكندرية لخسارة الدهون، شد الجسم، زيادة الكتلة العضلية، ورجوع تدريجي ومتابع للتمرين تحت إشراف مدربين وخبراء تغذية." 
} = Astro.props;
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#050a14" />
    
    <!-- SEO Title & Description -->
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph Metadata -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/logo.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    
    <!-- Preload critical images -->
    <link rel="preload" href="/logo-transparent.png" as="image" />
    <link rel="preload" href="/hero.webp" as="image" type="image/webp" fetchpriority="high" />
    
    <!-- Fonts Preconnect & Load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- JSON-LD Structured Data for Local Business -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "HealthAndBeautyBusiness",
        "name": "Easy Fit Alexandria",
        "image": "/logo.jpg",
        "telephone": "+201097710544",
        "priceRange": "$$",
        "address": [
          {
            "@type": "PostalAddress",
            "addressLocality": "Alexandria",
            "addressCountry": "EG",
            "streetAddress": "Smouha: أبراج دلتا لايف الإداري، شارع مستشفى المدينة للمرأة - خلف مول متاجر"
          },
          {
            "@type": "PostalAddress",
            "addressLocality": "Alexandria",
            "addressCountry": "EG",
            "streetAddress": "Ganaklis: أبراج الزراعيين، شارع أبو قير - أمام السلاب"
          }
        ]
      }
    </script>
    
    <!-- Pre-render theme/intro script to prevent Flash of Unwanted Content (FOUC) -->
    <script is:inline>
      (() => {
        const params = new URLSearchParams(window.location.search);
        const forceIntro = params.has('intro');
        const resetIntro = params.has('resetIntro');

        if (resetIntro) {
          try {
            sessionStorage.removeItem('easyfitIntroSeen');
          } catch (e) {
            // sessionStorage unavailable; continue gracefully.
          }
        }

        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        let introSeen = false;
        try {
          introSeen = sessionStorage.getItem('easyfitIntroSeen') === 'true';
        } catch (e) {
          // Privacy mode might block sessionStorage. Fail gracefully.
          introSeen = true; 
        }

        if (reducedMotion) {
          document.documentElement.classList.add('intro-done');
        } else if (forceIntro) {
          document.documentElement.classList.add('has-intro');
        } else if (introSeen) {
          document.documentElement.classList.add('intro-done');
        } else {
          document.documentElement.classList.add('has-intro');
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">تخطي إلى المحتوى الأساسي</a>
    
    <slot />
  </body>
</html>
