---
const whatsappUrl = 'https://wa.me/201124799978';
const explainerVideo = '/videos/ems-explainer.mp4';
const explainerPoster = '/videos/ems-explainer-poster.webp';
const emsPoints = ['Coach guided', 'Full-body activation', 'Built for busy schedules'];
---

<section class="section-padding ems-section" id="what-is-ems" aria-labelledby="ems-title">
  <div class="container">
    <div class="ems-demo-shell">
      <div class="ems-media-card reveal-on-scroll">
        <video
          data-src={explainerVideo}
          poster={explainerPoster}
          autoplay
          muted
          loop
          playsinline
          preload="none"
        ></video>
      </div>

      <div class="ems-copy-panel reveal-on-scroll reveal-delay-1">
        <h2 id="ems-title" class="section-title">EMS in 20 minutes.</h2>
        <p class="section-intro">
          A focused coach-guided session using EMS technology to activate your muscles while you move.
        </p>

        <ul class="ems-points" aria-label="EMS session benefits">
          {emsPoints.map((point) => <li>{point}</li>)}
        </ul>

        <p class="fine-note">EMS is training, not a shortcut.</p>

        <a class="btn btn-primary ems-cta" href="#booking-form">
          Book the 20-Min Trial
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const video = document.querySelector('.ems-media-card video');
    if (!(video instanceof HTMLVideoElement)) return;

    const loadVideo = () => {
      const videoSrc = video.dataset.src;
      if (videoSrc && !video.currentSrc) {
        video.src = videoSrc;
        video.load();
      }

      const attempt = video.play();
      if (attempt && typeof attempt.catch === 'function') {
        attempt.catch(() => {});
      }
    };

    if (!('IntersectionObserver' in window)) {
      loadVideo();
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        loadVideo();
        observer.disconnect();
      },
      { rootMargin: '500px 0px' }
    );

    observer.observe(video);
  })();
</script>
