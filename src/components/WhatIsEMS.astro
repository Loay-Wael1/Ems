---
---

<section class="section-padding ems-section" id="what-is-ems" aria-labelledby="ems-title">
  <div class="container">
    <div class="section-head center reveal-on-scroll">
      <span class="ems-eyebrow">EMS SYSTEMS</span>
      <h2 id="ems-title" class="section-title">20 minutes EMS = 4 hours in the gym</h2>
      <p class="section-intro">
        Three EMS systems. One smarter way to train, shape, and activate.
      </p>
    </div>

    <div class="ems-systems-showcase reveal-on-scroll reveal-delay-1">
      <!-- Two-column showcase -->
      <div class="systems-layout">
        <!-- Visual column (Stage + Tabs) -->
        <div class="systems-visual-column">
          <!-- Shared visual stage -->
          <div class="systems-stage" aria-hidden="true">
            <div class="stage-suits">
              <img src="/i-motion-stage-v2.webp" alt="" class="stage-suit active" data-suit="0" width="440" height="580" loading="eager" decoding="async" />
              <img src="/i-model-stage-v2.webp" alt="" class="stage-suit" data-suit="1" width="440" height="520" loading="lazy" decoding="async" />
              <img src="/i-shape-stage-v2.webp" alt="" class="stage-suit" data-suit="2" width="440" height="480" loading="lazy" decoding="async" />
            </div>
            <img src="/ems-stand-stage.webp" alt="" class="stage-stand" width="480" height="200" loading="eager" decoding="async" />
          </div>

          <!-- Tabs shifted below stage -->
          <div class="systems-tabs" role="tablist" aria-label="EMS Systems">
            <button type="button" role="tab" aria-selected="true" aria-controls="panel-imotion" id="tab-imotion" class="system-tab-btn active" data-index="0">I-MOTION</button>
            <button type="button" role="tab" aria-selected="false" aria-controls="panel-imodel" id="tab-imodel" class="system-tab-btn" data-index="1" tabindex="-1">I-MODEL</button>
            <button type="button" role="tab" aria-selected="false" aria-controls="panel-ishape" id="tab-ishape" class="system-tab-btn" data-index="2" tabindex="-1">I-SHAPE</button>
          </div>
        </div>

        <!-- Content panels -->
        <div class="systems-content">
          <div id="panel-imotion" role="tabpanel" aria-labelledby="tab-imotion" class="sys-panel active" data-panel="0">
            <h3 class="sys-name">I-MOTION</h3>
            <p class="sys-tagline">Full-body EMS for strength, movement, and transformation.</p>
            <p class="sys-desc">Built for active coach-guided sessions that activate the whole body in one efficient workout.</p>
            <div class="sys-chips" aria-label="I-MOTION features">
              <span class="sys-chip">Full-body activation</span>
              <span class="sys-chip">Coach-guided</span>
              <span class="sys-chip">20-minute format</span>
            </div>
            <p class="sys-best">Best for full-body training and overall transformation.</p>
          </div>

          <div id="panel-imodel" role="tabpanel" aria-labelledby="tab-imodel" class="sys-panel" data-panel="1" hidden>
            <h3 class="sys-name">I-MODEL</h3>
            <p class="sys-tagline">Targeted EMS for shaping and toning.</p>
            <p class="sys-desc">Designed to focus on areas like the abdomen, glutes, and thighs with more precise stimulation.</p>
            <div class="sys-chips" aria-label="I-MODEL features">
              <span class="sys-chip">Targeted shaping</span>
              <span class="sys-chip">Toning support</span>
              <span class="sys-chip">Aesthetic sessions</span>
            </div>
            <p class="sys-best">Best for contouring, toning, and body-shape goals.</p>
          </div>

          <div id="panel-ishape" role="tabpanel" aria-labelledby="tab-ishape" class="sys-panel" data-panel="2" hidden>
            <h3 class="sys-name">I-SHAPE</h3>
            <p class="sys-tagline">Advanced lower-body EMS for glutes and legs.</p>
            <p class="sys-desc">A focused EMS system for lower-body definition and high-value shaping sessions.</p>
            <div class="sys-chips" aria-label="I-SHAPE features">
              <span class="sys-chip">Lower-body focus</span>
              <span class="sys-chip">Glutes & legs</span>
              <span class="sys-chip">Premium shaping</span>
            </div>
            <p class="sys-best">Best for glute focus and lower-body definition.</p>
          </div>

          <div class="systems-cta-wrap">
            <a class="btn btn-primary" href="#booking-form">Book the 20-Minute Trial</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.querySelector('.ems-systems-showcase');
    if (!section) return;

    const tabs = Array.from(section.querySelectorAll('[role="tab"]'));
    const panels = Array.from(section.querySelectorAll('[role="tabpanel"]'));
    const suits = Array.from(section.querySelectorAll('.stage-suit'));

    const activate = (idx: number) => {
      // Update tabs
      tabs.forEach((t, i) => {
        const on = i === idx;
        t.setAttribute('aria-selected', String(on));
        t.setAttribute('tabindex', on ? '0' : '-1');
        t.classList.toggle('active', on);
      });

      // Morph suits — crossfade within shared stage
      suits.forEach((s, i) => {
        s.classList.toggle('active', i === idx);
      });

      // Switch content panels
      panels.forEach((p, i) => {
        const on = i === idx;
        if (on) {
          p.removeAttribute('hidden');
          void (p as HTMLElement).offsetWidth;
          p.classList.add('active');
        } else {
          p.classList.remove('active');
          p.setAttribute('hidden', '');
        }
      });
    };

    tabs.forEach((tab, idx) => {
      tab.addEventListener('click', () => {
        activate(idx);
        (tab as HTMLElement).focus();
      });

      tab.addEventListener('keydown', (e: Event) => {
        const ke = e as KeyboardEvent;
        let next = idx;
        if (ke.key === 'ArrowRight') next = (idx + 1) % tabs.length;
        else if (ke.key === 'ArrowLeft') next = (idx - 1 + tabs.length) % tabs.length;
        else if (ke.key === 'Home') next = 0;
        else if (ke.key === 'End') next = tabs.length - 1;
        else return;
        ke.preventDefault();
        activate(next);
        (tabs[next] as HTMLElement).focus();
      });
    });
  })();
</script>
