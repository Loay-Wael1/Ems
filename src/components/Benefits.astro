---
const benefits = [
  {
    title: 'Fat loss support',
    text: 'Structured sessions that support better consistency, body composition goals, and a more active routine.'
  },
  {
    title: 'Body toning',
    text: 'Focused work for shape, firmness, and a stronger look with guided full-body activation.'
  },
  {
    title: 'Muscle activation',
    text: 'EMS helps your body recruit muscle groups while your coach keeps the movement controlled.'
  },
  {
    title: 'Busy schedule',
    text: 'A premium 20-minute format built for people who need training to fit real life.'
  },
  {
    title: 'Return to training',
    text: 'A measured way to restart movement with professional guidance and smart intensity control.'
  },
  {
    title: 'Personal coaching',
    text: 'Every session is adjusted to your goal, your comfort, and the way your body responds.'
  }
];
---

<section class="section-padding benefits-section" id="benefits" aria-labelledby="benefits-title">
  <div class="container">
    <div class="section-head center reveal-on-scroll">
      <p class="eyebrow">GOALS</p>
      <h2 id="benefits-title" class="section-title">Choose your goal. We tune the session.</h2>
      <p class="section-intro">
        Easy Fit sessions are built for transformation, not generic training. Your coach adjusts the plan
        around what you want your body to do next.
      </p>
    </div>

    <div class="benefits-grid">
      {
        benefits.map((benefit, index) => (
          <article class="benefit-card reveal-on-scroll" style={`--card-index:${index}`}>
            <span class="benefit-index">{String(index + 1).padStart(2, '0')}</span>
            <h3>{benefit.title}</h3>
            <p>{benefit.text}</p>
          </article>
        ))
      }
    </div>

    <p class="fine-note center-note reveal-on-scroll">
      For medical conditions or recent injuries, consult your doctor before starting EMS training.
    </p>
  </div>
</section>
