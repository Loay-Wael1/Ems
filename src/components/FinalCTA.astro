---
import LeadForm from './LeadForm.astro';
import { siteContent, type Locale } from '../i18n/content';

interface Props {
  copy?: (typeof siteContent)[Locale]['finalCta'];
  leadFormCopy?: (typeof siteContent)[Locale]['leadForm'];
  locale?: Locale;
}

const { copy = siteContent.en.finalCta, leadFormCopy = siteContent.en.leadForm, locale = 'en' } = Astro.props;

const smouhaWhatsapp = 'https://wa.me/201124799978';
const instagramUrl = 'https://instagram.com/ems.easyfit.alexandria?igsh=MWV1NDlkcG1wc3dnYw==';
const facebookUrl = 'https://www.facebook.com/ems.easyfit.alexandria/?ref=NONE_xav_ig_profile_page_web#';
---

<section class="final-cta-section" id="booking-form" aria-labelledby="final-cta-title">
  <div class="container final-cta-shell reveal-on-scroll">
    <LeadForm copy={leadFormCopy} locale={locale} />
  </div>
</section>

<footer class="site-footer">
  <div class="container footer-container">
    <div class="footer-brand">
      <span class="footer-logo-wrap" aria-hidden="true">
        <img class="footer-logo footer-logo-light" src="/logo-transparent.png" alt="" width="42" height="42" loading="lazy" />
        <img class="footer-logo footer-logo-dark" src="/logo-night.png" alt="" width="42" height="42" loading="lazy" />
      </span>
      <div>
        <strong>Easy Fit Alexandria</strong>
        <span>{copy.brandSub}</span>
      </div>
    </div>

    <ul class="footer-links" aria-label={copy.socialLabel}>
      <li><a href={facebookUrl} target="_blank" rel="noopener noreferrer">{copy.links.facebook}</a></li>
      <li><a href={instagramUrl} target="_blank" rel="noopener noreferrer">{copy.links.instagram}</a></li>
      <li><a href={smouhaWhatsapp} target="_blank" rel="noopener noreferrer">{copy.links.whatsapp}</a></li>
    </ul>
    <p class="footer-copy">{copy.copyright}</p>
  </div>
</footer>
