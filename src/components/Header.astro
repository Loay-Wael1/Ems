---
const whatsappUrl = 'https://wa.me/201124799978';
const instagramUrl = 'https://instagram.com/ems.easyfit.alexandria?igsh=MWV1NDlkcG1wc3dnYw==';
const facebookUrl = 'https://www.facebook.com/ems.easyfit.alexandria/?ref=NONE_xav_ig_profile_page_web#';

const navItems = [
  { label: 'Results', href: '#results' },
  { label: 'EMS', href: '#why-ems' },
  { label: 'Benefits', href: '#benefits' },
  { label: 'Studios', href: '#locations' }
];
---

<header class="site-header" aria-label="Primary navigation">
  <div class="container header-container">
    <a class="brand" href="#main-content" aria-label="Easy Fit Alexandria home">
      <img class="brand-logo" src="/logo-transparent.png" alt="" width="48" height="48" />
      <span class="brand-text">
        <span class="brand-name">Easy Fit</span>
        <span class="brand-sub">Alexandria EMS Studio</span>
      </span>
    </a>

    <nav class="nav-links" aria-label="Page sections">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <div class="header-actions">
      <a class="social-link" href={instagramUrl} target="_blank" rel="noreferrer">IG</a>
      <a class="social-link" href={facebookUrl} target="_blank" rel="noreferrer">FB</a>
      <a class="btn btn-primary nav-cta" href={whatsappUrl} target="_blank" rel="noreferrer">
        <span class="cta-full">Book on WhatsApp</span>
        <span class="cta-short" aria-hidden="true">Book</span>
      </a>
    </div>
  </div>
</header>
