---
const whatsappUrl = 'https://wa.me/201124799978';
const instagramUrl = 'https://instagram.com/ems.easyfit.alexandria?igsh=MWV1NDlkcG1wc3dnYw==';
const facebookUrl = 'https://www.facebook.com/ems.easyfit.alexandria/?ref=NONE_xav_ig_profile_page_web#';

const navItems = [
  { label: 'Results', href: '#results' },
  { label: 'Systems', href: '#what-is-ems' },
  { label: 'EMS', href: '#why-ems' },
  { label: 'Reviews', href: '#testimonials' },
  { label: 'Branches', href: '#locations' }
];
---

<header class="site-header" aria-label="Primary navigation">
  <div class="container header-container">
    <a class="brand" href="#main-content">
      <span class="brand-logo-wrap" aria-hidden="true">
        <img class="brand-logo brand-logo-light" src="/logo-transparent.png" alt="" width="48" height="48" />
        <img class="brand-logo brand-logo-dark" src="/logo-dark-clean.webp" alt="" width="48" height="48" />
      </span>
      <span class="brand-text">
        <span class="brand-name">Easy Fit Alexandria</span>
        <span class="brand-sub">EMS Studios</span>
      </span>
    </a>

    <nav class="nav-links" aria-label="Page sections">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <div class="header-actions">
      <a class="social-link" href={instagramUrl} target="_blank" rel="noopener noreferrer" aria-label="Instagram">IG</a>
      <a class="social-link" href={facebookUrl} target="_blank" rel="noopener noreferrer" aria-label="Facebook">FB</a>
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch to dark mode" aria-pressed="false">
        <span class="theme-toggle-icon" aria-hidden="true">
          <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" focusable="false">
            <path d="M20.5 14.7A8.4 8.4 0 0 1 9.3 3.5a8.6 8.6 0 1 0 11.2 11.2Z" />
          </svg>
          <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" focusable="false">
            <circle cx="12" cy="12" r="4.2" />
            <path d="M12 2.6v2.2M12 19.2v2.2M4.8 4.8l1.6 1.6M17.6 17.6l1.6 1.6M2.6 12h2.2M19.2 12h2.2M4.8 19.2l1.6-1.6M17.6 6.4l1.6-1.6" />
          </svg>
        </span>
        <span class="theme-toggle-text">Night</span>
      </button>
      <a class="btn btn-primary nav-cta" href="#booking-form" aria-label="Book Trial">
        <span class="cta-full">Book Trial</span>
        <span class="cta-short" aria-hidden="true">Book</span>
      </a>
    </div>
  </div>
</header>

<script>
  (() => {
    const html = document.documentElement;
    const buttons = document.querySelectorAll('[data-theme-toggle]');

    const setTheme = (theme, shouldStore = true) => {
      html.dataset.theme = theme;
      html.style.colorScheme = theme;
      document
        .querySelector('meta[name="theme-color"]')
        ?.setAttribute('content', theme === 'dark' ? '#05030A' : '#F8FAFC');

      buttons.forEach((button) => {
        const text = button.querySelector('.theme-toggle-text');
        const isDark = theme === 'dark';
        button.setAttribute('aria-pressed', String(isDark));
        button.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
        if (text) text.textContent = isDark ? 'Light' : 'Night';
      });

      if (shouldStore) {
        try {
          localStorage.setItem('easyfitTheme', theme);
        } catch (error) {
          /* Theme still works for the current page if storage is unavailable. */
        }
      }
    };

    const currentTheme = html.dataset.theme === 'dark' ? 'dark' : 'light';
    setTheme(currentTheme, false);

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        setTheme(html.dataset.theme === 'dark' ? 'light' : 'dark');
      });
    });

    window.addEventListener('storage', (event) => {
      if (event.key === 'easyfitTheme') {
        setTheme(event.newValue === 'dark' ? 'dark' : 'light', false);
      }
    });
  })();
</script>
