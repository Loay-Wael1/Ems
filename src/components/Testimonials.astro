---
import reviewOne from '../../clint review/Screenshot 2026-07-02 010221.png';
import reviewTwo from '../../clint review/Screenshot 2026-07-02 010228.png';
import reviewThree from '../../clint review/Screenshot 2026-07-02 010235.png';
import reviewFour from '../../clint review/Screenshot 2026-07-02 010240.png';
import reviewFive from '../../clint review/Screenshot 2026-07-02 010246.png';
import reviewSix from '../../clint review/Screenshot 2026-07-02 010252.png';
import reviewSeven from '../../clint review/Screenshot 2026-07-02 010257.png';
import reviewEight from '../../clint review/Screenshot 2026-07-02 010317.png';
import reviewNine from '../../clint review/Screenshot 2026-07-02 010324.png';
import reviewTen from '../../clint review/Screenshot 2026-07-02 010333.png';
import reviewEleven from '../../clint review/Screenshot 2026-07-02 010356.png';

const whatsappUrl = 'https://wa.me/201124799978';

const reviews = [
  reviewOne,
  reviewTwo,
  reviewThree,
  reviewFour,
  reviewFive,
  reviewSix,
  reviewSeven,
  reviewEight,
  reviewNine,
  reviewTen,
  reviewEleven
].map((image, index) => ({
  image,
  title: `Client review ${index + 1}`
}));
---

<section class="section-padding reviews-section" id="testimonials" aria-labelledby="reviews-title">
  <div class="container">
    <div class="section-head center reveal-on-scroll">
      <h2 id="reviews-title" class="section-title">Real people. Real feedback.</h2>
      <p class="section-intro">
        See what Easy Fit clients shared after trying EMS sessions in Alexandria.
      </p>
    </div>
  </div>

  <div class="review-marquee reveal-on-scroll" data-review-marquee aria-label="Client review screenshots">
    <div class="review-marquee-track">
      {
        [...reviews, ...reviews].map((review) => (
          <button
            class="review-card"
            type="button"
            data-review-card
            data-full={review.image.src}
            data-title={review.title}
            aria-label={`Open ${review.title}`}
          >
            <img
              src={review.image.src}
              width={review.image.width}
              height={review.image.height}
              alt={`${review.title} from Easy Fit Alexandria client`}
              loading="lazy"
              decoding="async"
            />
          </button>
        ))
      }
    </div>
  </div>

  <div class="container review-cta-row reveal-on-scroll">
    <p>Want to feel the difference yourself?</p>
    <a class="btn btn-primary" href={whatsappUrl} target="_blank" rel="noreferrer">Book on WhatsApp</a>
  </div>

  <dialog class="review-modal" aria-label="Client review preview">
    <div class="review-modal-card">
      <button class="modal-close-button" type="button" data-review-close aria-label="Close review preview">
        ×
      </button>
      <img id="review-modal-image" src="" alt="" />
    </div>
  </dialog>
</section>

<script>
  (() => {
    const marquee = document.querySelector('[data-review-marquee]');
    const track = marquee?.querySelector('.review-marquee-track');
    const modal = document.querySelector('.review-modal');
    const modalImage = document.querySelector('#review-modal-image');
    const closeButton = document.querySelector('[data-review-close]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    if (!marquee || !track || !modal || !modalImage) return;

    let raf = null;
    let lastTime = 0;
    let isDragging = false;
    let hasMoved = false;
    let suppressClick = false;
    let isModalOpen = false;
    let startX = 0;
    let startScrollLeft = 0;
    let lastReviewTrigger = null;
    const speed = 65;

    const loopWidth = () => track.scrollWidth / 2;

    const normalize = () => {
      const half = loopWidth();
      if (!half) return;
      if (marquee.scrollLeft >= half) marquee.scrollLeft -= half;
      if (marquee.scrollLeft < 1) marquee.scrollLeft += half;
    };

    const animate = (time = 0) => {
      if (!lastTime) lastTime = time;
      const delta = Math.min((time - lastTime) / 1000, 0.08);
      lastTime = time;

      if (!isDragging && !isModalOpen && !reducedMotion.matches) {
        marquee.scrollLeft += speed * delta;
        normalize();
      }

      raf = requestAnimationFrame(animate);
    };

    const closeModal = () => {
      if (!modal.open) return;
      modal.close();
      isModalOpen = false;
      modalImage.removeAttribute('src');
      modalImage.removeAttribute('alt');
      lastReviewTrigger?.focus();
    };

    const openModal = (card) => {
      lastReviewTrigger = card;
      isModalOpen = true;
      modalImage.src = card.dataset.full || '';
      modalImage.alt = `${card.dataset.title || 'Client review'} from Easy Fit Alexandria`;
      modal.showModal();
      closeButton?.focus();
    };

    const endDrag = (event) => {
      if (!isDragging) return;
      isDragging = false;
      marquee.classList.remove('is-dragging');
      marquee.releasePointerCapture?.(event.pointerId);

      if (hasMoved) {
        suppressClick = true;
        window.setTimeout(() => {
          suppressClick = false;
          hasMoved = false;
        }, 150);
      }
    };

    marquee.scrollLeft = 1;
    raf = requestAnimationFrame(animate);

    marquee.addEventListener('pointerdown', (event) => {
      isDragging = true;
      hasMoved = false;
      startX = event.clientX;
      startScrollLeft = marquee.scrollLeft;
      marquee.classList.add('is-dragging');
      marquee.setPointerCapture?.(event.pointerId);
    });

    marquee.addEventListener('pointermove', (event) => {
      if (!isDragging) return;
      const delta = event.clientX - startX;
      if (Math.abs(delta) > 5) hasMoved = true;
      if (!hasMoved) return;
      event.preventDefault();
      marquee.scrollLeft = startScrollLeft - delta;
      normalize();
    });

    marquee.addEventListener('pointerup', endDrag);
    marquee.addEventListener('pointercancel', endDrag);
    marquee.addEventListener('pointerleave', endDrag);
    marquee.addEventListener('scroll', normalize, { passive: true });

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const card = target.closest('[data-review-card]');
      if (!card) return;

      if (suppressClick) {
        event.preventDefault();
        return;
      }

      openModal(card);
    });

    reducedMotion.addEventListener?.('change', () => {
      marquee.scrollLeft = reducedMotion.matches ? 0 : 1;
      lastTime = 0;
    });

    closeButton?.addEventListener('click', closeModal);
    modal.addEventListener('click', (event) => {
      if (event.target === modal) closeModal();
    });
    modal.addEventListener('cancel', (event) => {
      event.preventDefault();
      closeModal();
    });

    window.addEventListener('beforeunload', () => {
      if (raf) cancelAnimationFrame(raf);
    }, { once: true });
  })();
</script>
