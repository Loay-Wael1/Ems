---
import reviewOne from '../../clint review/Screenshot 2026-07-02 010221.png';
import reviewTwo from '../../clint review/Screenshot 2026-07-02 010228.png';
import reviewThree from '../../clint review/Screenshot 2026-07-02 010235.png';
import reviewFour from '../../clint review/Screenshot 2026-07-02 010240.png';
import reviewFive from '../../clint review/Screenshot 2026-07-02 010246.png';
import reviewSix from '../../clint review/Screenshot 2026-07-02 010252.png';
import reviewSeven from '../../clint review/Screenshot 2026-07-02 010257.png';
import reviewEight from '../../clint review/Screenshot 2026-07-02 010317.png';
import reviewNine from '../../clint review/Screenshot 2026-07-02 010324.png';
import reviewTen from '../../clint review/Screenshot 2026-07-02 010333.png';
import reviewEleven from '../../clint review/Screenshot 2026-07-02 010356.png';

const whatsappUrl = 'https://wa.me/201124799978';

const reviews = [
  reviewOne,
  reviewTwo,
  reviewThree,
  reviewFour,
  reviewFive,
  reviewSix,
  reviewSeven,
  reviewEight,
  reviewNine,
  reviewTen,
  reviewEleven
].map((image, index) => ({
  image,
  title: `Client review ${index + 1}`
}));

const reelVideos = [
  { src: '/feedback/1.mp4', poster: '/posters/feedback-1.jpg', title: 'Easy Fit Experience' },
  { src: '/feedback/2.mp4', poster: '/posters/feedback-2.jpg', title: 'Real Client Feedback' },
  { src: '/feedback/3.mp4', poster: '/posters/feedback-3.jpg', title: 'EMS Session Review' }
];
---

<section class="section-padding reviews-section" id="testimonials" aria-labelledby="reviews-title">
  <div class="container">
    <div class="section-head center reveal-on-scroll">
      <p class="eyebrow">CLIENT REVIEWS</p>
      <h2 id="reviews-title" class="section-title">Real people. Real feedback.</h2>
      <p class="section-intro">
        See what Easy Fit clients shared after trying EMS sessions in Alexandria.
      </p>
    </div>
  </div>

  <div class="review-marquee reveal-on-scroll" aria-label="Client review screenshots">
    <div class="review-marquee-track">
      {
        [...reviews, ...reviews].map((review, index) => (
          <button
            class="review-card"
            type="button"
            data-review-card
            data-full={review.image.src}
            data-title={review.title}
            aria-label={`Open ${review.title}`}
          >
            <img
              src={review.image.src}
              width={review.image.width}
              height={review.image.height}
              alt={`${review.title} from Easy Fit Alexandria client`}
              loading="lazy"
              decoding="async"
            />
            <span>Tap to zoom</span>
          </button>
        ))
      }
    </div>
  </div>

  <div class="container review-cta-row reveal-on-scroll">
    <p>Want to feel the difference yourself?</p>
    <a class="btn btn-primary" href={whatsappUrl} target="_blank" rel="noreferrer">Book on WhatsApp</a>
  </div>

  <div class="container mini-reels reveal-on-scroll">
    <div class="mini-reels-head">
      <span>VIDEO FEEDBACK</span>
      <p>Short client moments, opened only when you choose to play.</p>
    </div>
    <div class="mini-video-grid">
      {
        reelVideos.map((video, index) => (
          <button
            class="mini-video-card"
            type="button"
            data-video-card
            data-src={video.src}
            data-title={video.title}
            aria-label={`Play ${video.title}`}
          >
            <img
              src={video.poster}
              width="720"
              height="1280"
              alt={`${video.title} poster`}
              loading="lazy"
              decoding="async"
            />
            <span class="play-badge" aria-hidden="true">Play</span>
            <strong>{video.title}</strong>
          </button>
        ))
      }
    </div>
  </div>

  <dialog class="review-modal" aria-label="Client review preview">
    <div class="review-modal-card">
      <button class="modal-close-button" type="button" data-review-close aria-label="Close review preview">
        Close
      </button>
      <img id="review-modal-image" src="" alt="" />
    </div>
  </dialog>

  <dialog class="video-modal" aria-label="Client feedback video">
    <div class="video-modal-card">
      <div class="modal-topbar">
        <p id="video-modal-title">Client feedback</p>
        <button class="modal-close-button" type="button" data-video-close aria-label="Close video">Close</button>
      </div>
      <video id="modal-video" class="modal-video" controls playsinline preload="metadata"></video>
    </div>
  </dialog>
</section>

<script>
  (() => {
    const body = document.body;

    const reviewModal = document.querySelector('.review-modal');
    const reviewImage = document.querySelector('#review-modal-image');
    const reviewClose = document.querySelector('[data-review-close]');
    let lastReviewTrigger = null;

    const closeReview = () => {
      if (!reviewModal || !reviewModal.open) return;
      reviewModal.close();
      body.classList.remove('modal-open');
      if (reviewImage) {
        reviewImage.removeAttribute('src');
        reviewImage.removeAttribute('alt');
      }
      lastReviewTrigger?.focus();
    };

    document.querySelectorAll('[data-review-card]').forEach((card) => {
      card.addEventListener('click', () => {
        lastReviewTrigger = card;
        if (!reviewModal || !reviewImage) return;
        reviewImage.src = card.dataset.full || '';
        reviewImage.alt = `${card.dataset.title || 'Client review'} from Easy Fit Alexandria`;
        reviewModal.showModal();
        body.classList.add('modal-open');
        reviewClose?.focus();
      });
    });

    reviewClose?.addEventListener('click', closeReview);
    reviewModal?.addEventListener('click', (event) => {
      if (event.target === reviewModal) closeReview();
    });
    reviewModal?.addEventListener('cancel', (event) => {
      event.preventDefault();
      closeReview();
    });

    const videoModal = document.querySelector('.video-modal');
    const modalVideo = document.querySelector('#modal-video');
    const videoTitle = document.querySelector('#video-modal-title');
    const videoClose = document.querySelector('[data-video-close]');
    let lastVideoTrigger = null;

    const closeVideo = () => {
      if (!videoModal || !videoModal.open || !modalVideo) return;
      modalVideo.pause();
      modalVideo.removeAttribute('src');
      modalVideo.load();
      videoModal.close();
      body.classList.remove('modal-open');
      lastVideoTrigger?.focus();
    };

    document.querySelectorAll('[data-video-card]').forEach((card) => {
      card.addEventListener('click', () => {
        lastVideoTrigger = card;
        if (!videoModal || !modalVideo || !videoTitle) return;
        videoTitle.textContent = card.dataset.title || 'Client feedback';
        modalVideo.src = card.dataset.src || '';
        videoModal.showModal();
        body.classList.add('modal-open');
        modalVideo.play().catch(() => {});
      });
    });

    videoClose?.addEventListener('click', closeVideo);
    videoModal?.addEventListener('click', (event) => {
      if (event.target === videoModal) closeVideo();
    });
    videoModal?.addEventListener('cancel', (event) => {
      event.preventDefault();
      closeVideo();
    });
  })();
</script>
