<section class="section-padding testimonials-section" id="testimonials">
  <div class="container">
    <div class="section-head">
      <p class="section-eyebrow reveal-on-scroll">آراء العملاء</p>
      <h2 class="section-title reveal-on-scroll reveal-delay-1">اسمعها من الناس اللي جرّبت.</h2>
      <p class="section-intro-text reveal-on-scroll reveal-delay-2">
        إحنا ممكن نتكلم عن EMS كتير… بس كلام العملاء بعد التجربة هو اللي يفرق.
      </p>
    </div>

    <!-- Testimonials Video Grid -->
    <div class="video-grid" aria-label="آراء وتجارب عملاء إيزي فيت">
      
      <!-- Video 1 -->
      <button class="video-card reveal-on-scroll" type="button" data-video="/feedback/1.mp4" data-title="تجربة عميل" aria-label="تشغيل فيديو تجربة عميل">
        <div class="video-thumbnail-container">
          <img src="/posters/feedback-1.jpg" class="video-poster-img" alt="تجربة عميل" loading="lazy" width="360" height="640" />
          <div class="video-overlay">
            <span class="video-play-btn">
              <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </div>
        </div>
        <div class="video-card-info">
          <h3 class="video-card-title">تجربة عميل</h3>
          <span class="video-card-subtitle en">Feedback · 0:22</span>
        </div>
      </button>

      <!-- Video 2 -->
      <button class="video-card reveal-on-scroll reveal-delay-1" type="button" data-video="/feedback/2.mp4" data-title="بعد أول جلسة" aria-label="تشغيل فيديو بعد أول جلسة">
        <div class="video-thumbnail-container">
          <img src="/posters/feedback-2.jpg" class="video-poster-img" alt="بعد أول جلسة تمرين" loading="lazy" width="360" height="640" />
          <div class="video-overlay">
            <span class="video-play-btn">
              <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </div>
        </div>
        <div class="video-card-info">
          <h3 class="video-card-title">بعد أول جلسة</h3>
          <span class="video-card-subtitle en">Feedback · 0:26</span>
        </div>
      </button>

      <!-- Video 3 -->
      <button class="video-card reveal-on-scroll reveal-delay-2" type="button" data-video="/feedback/3.mp4" data-title="إحساس التمرين" aria-label="تشغيل فيديو إحساس التمرين">
        <div class="video-thumbnail-container">
          <img src="/posters/feedback-3.jpg" class="video-poster-img" alt="إحساس التمرين العضلي" loading="lazy" width="360" height="640" />
          <div class="video-overlay">
            <span class="video-play-btn">
              <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </div>
        </div>
        <div class="video-card-info">
          <h3 class="video-card-title">إحساس التمرين</h3>
          <span class="video-card-subtitle en">Feedback · 0:32</span>
        </div>
      </button>

      <!-- Video 4 -->
      <button class="video-card reveal-on-scroll reveal-delay-3" type="button" data-video="/اعلان.mp4" data-title="رأي من Easy Fit" aria-label="تشغيل فيديو رأي من Easy Fit">
        <div class="video-thumbnail-container">
          <img src="/posters/studio-1.jpg" class="video-poster-img" alt="رأي من استوديو إيزي فيت" loading="lazy" width="360" height="640" />
          <div class="video-overlay">
            <span class="video-play-btn">
              <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </div>
        </div>
        <div class="video-card-info">
          <h3 class="video-card-title">رأي من Easy Fit</h3>
          <span class="video-card-subtitle en">Studio media · 0:15</span>
        </div>
      </button>

      <!-- Video 5 -->
      <button class="video-card reveal-on-scroll reveal-delay-4" type="button" data-video="/اعلان 1.mp4" data-title="تجربة الاستوديو" aria-label="تشغيل فيديو تجربة الاستوديو">
