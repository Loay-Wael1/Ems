---
import reviewOne from '../../clint review/Screenshot 2026-07-02 010221.png';
import reviewTwo from '../../clint review/Screenshot 2026-07-02 010228.png';
import reviewThree from '../../clint review/Screenshot 2026-07-02 010235.png';
import reviewFour from '../../clint review/Screenshot 2026-07-02 010240.png';
import reviewFive from '../../clint review/Screenshot 2026-07-02 010246.png';
import reviewSix from '../../clint review/Screenshot 2026-07-02 010252.png';
import reviewSeven from '../../clint review/Screenshot 2026-07-02 010257.png';
import reviewEight from '../../clint review/Screenshot 2026-07-02 010317.png';
import reviewNine from '../../clint review/Screenshot 2026-07-02 010324.png';
import reviewTen from '../../clint review/Screenshot 2026-07-02 010333.png';
import reviewEleven from '../../clint review/Screenshot 2026-07-02 010356.png';

const whatsappUrl = 'https://wa.me/201124799978';

const reviews = [
  reviewOne,
  reviewTwo,
  reviewThree,
  reviewFour,
  reviewFive,
  reviewSix,
  reviewSeven,
  reviewEight,
  reviewNine,
  reviewTen,
  reviewEleven
].map((image, index) => ({
  image,
  title: `Client review ${index + 1}`
}));
---

<section class="section-padding reviews-section" id="testimonials" aria-labelledby="reviews-title">
  <div class="container">
    <div class="section-head center reveal-on-scroll">
      <p class="eyebrow">CLIENT REVIEWS</p>
      <h2 id="reviews-title" class="section-title">Real people. Real feedback.</h2>
      <p class="section-intro">
        See what Easy Fit clients shared after trying EMS sessions in Alexandria.
      </p>
    </div>
  </div>

  <div class="review-marquee reveal-on-scroll" data-review-marquee aria-label="Client review screenshots">
    <div class="review-marquee-track">
      {
        [...reviews, ...reviews].map((review) => (
          <button
            class="review-card"
            type="button"
            data-review-card
            data-full={review.image.src}
            data-title={review.title}
            aria-label={`Open ${review.title}`}
          >
            <img
              src={review.image.src}
              width={review.image.width}
              height={review.image.height}
              alt={`${review.title} from Easy Fit Alexandria client`}
              loading="lazy"
              decoding="async"
            />
          </button>
        ))
      }
    </div>
  </div>

  <div class="container review-cta-row reveal-on-scroll">
    <p>Want to feel the difference yourself?</p>
    <a class="btn btn-primary" href={whatsappUrl} target="_blank" rel="noreferrer">Book on WhatsApp</a>
  </div>

  <dialog class="review-modal" aria-label="Client review preview">
    <div class="review-modal-card">
      <button class="modal-close-button" type="button" data-review-close aria-label="Close review preview">
        Close
      </button>
      <img id="review-modal-image" src="" alt="" />
    </div>
  </dialog>
</section>

<script>
  (() => {
    const body = document.body;
    const marquee = document.querySelector('[data-review-marquee]');
    const track = marquee?.querySelector('.review-marquee-track');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    let isDragging = false;
    let isPaused = false;
    let startX = 0;
    let startScrollLeft = 0;
    let animationFrame = 0;
    let resumeTimer = 0;
    let virtualScrollLeft = 1;
    let lastFrameTime = 0;
    const autoSpeed = 24;

    const getLoopWidth = () => {
      if (!track) return 0;
      return track.scrollWidth / 2;
    };

    const normalizeScroll = () => {
      if (!marquee) return;
      const loopWidth = getLoopWidth();
      if (!loopWidth) return;
      if (virtualScrollLeft >= loopWidth) virtualScrollLeft -= loopWidth;
      if (virtualScrollLeft <= 0) virtualScrollLeft += loopWidth;
      marquee.scrollLeft = virtualScrollLeft;
    };

    const autoMove = (timestamp = 0) => {
      if (!lastFrameTime) lastFrameTime = timestamp;
      const deltaSeconds = Math.min((timestamp - lastFrameTime) / 1000, 0.08);
      lastFrameTime = timestamp;

      if (marquee && !reducedMotion.matches && !isPaused && !isDragging) {
        virtualScrollLeft += autoSpeed * deltaSeconds;
        marquee.scrollLeft = virtualScrollLeft;
        normalizeScroll();
      }
      animationFrame = requestAnimationFrame(autoMove);
    };

    const pause = () => {
      isPaused = true;
      window.clearTimeout(resumeTimer);
    };

    const resume = () => {
      window.clearTimeout(resumeTimer);
      resumeTimer = window.setTimeout(() => {
        isPaused = false;
      }, 700);
    };

    if (marquee && track) {
      marquee.scrollLeft = 1;
      virtualScrollLeft = marquee.scrollLeft;
      animationFrame = requestAnimationFrame(autoMove);

      marquee.addEventListener('mouseenter', pause);
      marquee.addEventListener('mouseleave', resume);
      marquee.addEventListener('focusin', pause);
      marquee.addEventListener('focusout', resume);

      marquee.addEventListener('pointerdown', (event) => {
        isDragging = true;
        pause();
        startX = event.clientX;
        startScrollLeft = marquee.scrollLeft;
        marquee.classList.add('is-dragging');
        marquee.setPointerCapture?.(event.pointerId);
      });

      marquee.addEventListener('pointermove', (event) => {
        if (!isDragging) return;
        event.preventDefault();
        const delta = event.clientX - startX;
        marquee.scrollLeft = startScrollLeft - delta;
        virtualScrollLeft = marquee.scrollLeft;
        normalizeScroll();
      });

      const endDrag = (event) => {
        if (!isDragging) return;
        isDragging = false;
        marquee.classList.remove('is-dragging');
        marquee.releasePointerCapture?.(event.pointerId);
        resume();
      };

      marquee.addEventListener('pointerup', endDrag);
      marquee.addEventListener('pointercancel', endDrag);
      marquee.addEventListener('scroll', () => {
        if (isDragging) virtualScrollLeft = marquee.scrollLeft;
      }, { passive: true });
    }

    reducedMotion.addEventListener?.('change', () => {
      if (marquee) marquee.scrollLeft = 0;
    });

    window.addEventListener('beforeunload', () => cancelAnimationFrame(animationFrame), { once: true });

    const reviewModal = document.querySelector('.review-modal');
    const reviewImage = document.querySelector('#review-modal-image');
    const reviewClose = document.querySelector('[data-review-close]');
    let lastReviewTrigger = null;

    const closeReview = () => {
      if (!reviewModal || !reviewModal.open) return;
      reviewModal.close();
      body.classList.remove('modal-open');
      if (reviewImage) {
        reviewImage.removeAttribute('src');
        reviewImage.removeAttribute('alt');
      }
      lastReviewTrigger?.focus();
      resume();
    };

    document.querySelectorAll('[data-review-card]').forEach((card) => {
      card.addEventListener('click', () => {
        lastReviewTrigger = card;
        if (!reviewModal || !reviewImage) return;
        pause();
        reviewImage.src = card.dataset.full || '';
        reviewImage.alt = `${card.dataset.title || 'Client review'} from Easy Fit Alexandria`;
        reviewModal.showModal();
        body.classList.add('modal-open');
        reviewClose?.focus();
      });
    });

    reviewClose?.addEventListener('click', closeReview);
    reviewModal?.addEventListener('click', (event) => {
      if (event.target === reviewModal) closeReview();
    });
    reviewModal?.addEventListener('cancel', (event) => {
      event.preventDefault();
      closeReview();
    });
  })();
</script>
