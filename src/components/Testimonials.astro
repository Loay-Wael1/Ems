---
import reviewOne from '../../clint review/Screenshot 2026-07-02 010221.png';
import reviewTwo from '../../clint review/Screenshot 2026-07-02 010228.png';
import reviewThree from '../../clint review/Screenshot 2026-07-02 010235.png';
import reviewFour from '../../clint review/Screenshot 2026-07-02 010240.png';
import reviewFive from '../../clint review/Screenshot 2026-07-02 010246.png';
import reviewSix from '../../clint review/Screenshot 2026-07-02 010252.png';
import reviewSeven from '../../clint review/Screenshot 2026-07-02 010257.png';
import reviewEight from '../../clint review/Screenshot 2026-07-02 010317.png';
import reviewNine from '../../clint review/Screenshot 2026-07-02 010324.png';
import reviewTen from '../../clint review/Screenshot 2026-07-02 010333.png';
import reviewEleven from '../../clint review/Screenshot 2026-07-02 010356.png';

const reviews = [
  reviewOne,
  reviewTwo,
  reviewThree,
  reviewFour,
  reviewFive,
  reviewSix,
  reviewSeven,
  reviewEight,
  reviewNine,
  reviewTen,
  reviewEleven
].map((image, index) => ({
  image,
  title: `Client review ${index + 1}`
}));

const videoReviews = [
  {
    src: '/videos/reviews/client-review-1.mp4',
    title: 'Client video review 1'
  },
  {
    src: '/videos/reviews/client-review-2.mp4',
    title: 'Client video review 2'
  },
  {
    src: '/videos/reviews/client-review-3.mp4',
    title: 'Client video review 3'
  },
  {
    src: '/videos/reviews/client-review-4.mp4',
    title: 'Client video review 4'
  }
];
---

<section class="section-padding reviews-section" id="testimonials" aria-labelledby="reviews-title">
  <div class="container">
    <div class="section-head center review-heading reveal-on-scroll">
      <span class="section-kicker">CLIENT FEEDBACK</span>
      <h2 id="reviews-title" class="section-title">Real people. Real feedback.</h2>
      <p class="section-intro">
        Watch client stories and browse real feedback from Easy Fit Alexandria.
      </p>
      <ul class="review-heading-chips" aria-label="Review formats">
        <li>Video reviews</li>
        <li>Client screenshots</li>
        <li>Alexandria EMS</li>
      </ul>
    </div>
  </div>

  <div class="review-carousel-shell review-video-shell reveal-on-scroll">
    <div class="review-marquee review-video-marquee" data-review-scroll aria-label="Client video reviews">
      <div class="review-marquee-track">
        {
          videoReviews.map((review) => (
            <button
              class="review-card review-video-card"
              type="button"
              data-review-card
              data-review-type="video"
              data-full={review.src}
              data-title={review.title}
              aria-label={`Open ${review.title}`}
            >
              <video
                class="review-preview-video"
                data-src={review.src}
                muted
                playsinline
                preload="metadata"
                aria-hidden="true"
              ></video>
              <span class="review-play-badge" aria-hidden="true"></span>
            </button>
          ))
        }
      </div>
    </div>
  </div>

  <div class="review-carousel-shell reveal-on-scroll">
    <div id="review-marquee" class="review-marquee" data-review-marquee data-review-scroll aria-label="Client review screenshots">
      <div class="review-marquee-track">
        {
          reviews.map((review) => (
            <button
              class="review-card"
              type="button"
              data-review-card
              data-review-type="image"
              data-full={review.image.src}
              data-title={review.title}
              aria-label={`Open ${review.title}`}
            >
              <img
                src={review.image.src}
                width={review.image.width}
                height={review.image.height}
                alt={`${review.title} from Easy Fit Alexandria client`}
                loading="lazy"
                decoding="async"
                draggable="false"
              />
            </button>
          ))
        }
      </div>
    </div>
  </div>

  <div class="container review-controls-bar reveal-on-scroll">
    <div class="review-controls" aria-label="Review carousel controls">
      <button class="review-nav" type="button" data-review-prev aria-label="Show previous reviews" aria-controls="review-marquee">
        <span aria-hidden="true">&lsaquo;</span>
      </button>
      <button class="review-nav" type="button" data-review-next aria-label="Show next reviews" aria-controls="review-marquee">
        <span aria-hidden="true">&rsaquo;</span>
      </button>
    </div>
  </div>

  <div class="container review-cta-row reveal-on-scroll">
    <p>Want to feel the difference yourself?</p>
    <a class="btn btn-primary" href="#booking-form">Book Your Trial</a>
  </div>

  <dialog class="review-modal" aria-label="Client review preview" aria-modal="true">
    <div class="review-modal-card">
      <button class="modal-close-button" type="button" data-review-close aria-label="Close review preview">
        &times;
      </button>
      <img id="review-modal-image" src="" alt="" hidden />
      <video id="review-modal-video" controls playsinline hidden></video>
    </div>
  </dialog>
</section>

<script>
  (() => {
    const section = document.querySelector('#testimonials');
    const marquee = document.querySelector('[data-review-marquee]');
    const scrollAreas = document.querySelectorAll('[data-review-scroll]');
    const modal = document.querySelector('.review-modal');
    const modalImage = document.querySelector('#review-modal-image');
    const modalVideo = document.querySelector('#review-modal-video');
    const closeButton = document.querySelector('[data-review-close]');
    const previousButton = document.querySelector('[data-review-prev]');
    const nextButton = document.querySelector('[data-review-next]');

    if (!section || !marquee || !modal || !modalImage || !modalVideo) return;

    let isDragging = false;
    let hasMoved = false;
    let suppressClick = false;
    let startX = 0;
    let startScrollLeft = 0;
    let activeScrollArea = null;
    let lastReviewTrigger = null;
    let openedByKeyboard = false;
    const dragThreshold = 8;
    const suppressClickDelay = 180;

    const maxScrollLeft = () => Math.max(0, marquee.scrollWidth - marquee.clientWidth);

    const updateControls = () => {
      const max = maxScrollLeft();
      const atStart = marquee.scrollLeft <= 2;
      const atEnd = marquee.scrollLeft >= max - 2;

      if (previousButton instanceof HTMLButtonElement) previousButton.disabled = atStart;
      if (nextButton instanceof HTMLButtonElement) nextButton.disabled = atEnd || max <= 0;
    };

    const scrollReviews = (direction) => {
      const card = marquee.querySelector('[data-review-card]');
      const cardWidth = card instanceof HTMLElement ? card.offsetWidth : 0;
      const amount = Math.max(cardWidth + 16, marquee.clientWidth * 0.72);
      marquee.scrollBy({ left: direction * amount, behavior: 'smooth' });
      window.setTimeout(updateControls, 260);
    };

    const resetModalVideo = () => {
      if (!(modalVideo instanceof HTMLVideoElement)) return;
      modalVideo.pause();
      modalVideo.hidden = true;
      modalVideo.removeAttribute('src');
      modalVideo.removeAttribute('aria-label');
      modalVideo.load();
    };

    const resetModalImage = () => {
      if (!(modalImage instanceof HTMLImageElement)) return;
      modalImage.hidden = true;
      modalImage.removeAttribute('src');
      modalImage.removeAttribute('alt');
    };

    const closeModal = () => {
      if (!modal.open) return;
      if (typeof modal.close === 'function') {
        modal.close();
      } else {
        modal.removeAttribute('open');
      }
      isDragging = false;
      hasMoved = false;
      suppressClick = false;
      modal.removeAttribute('data-active-type');
      resetModalImage();
      resetModalVideo();
      scrollAreas.forEach((area) => area.classList.remove('is-dragging'));

      if (openedByKeyboard) {
        lastReviewTrigger?.focus?.();
      }
      openedByKeyboard = false;
    };

    const openModal = (card, byKeyboard = false) => {
      lastReviewTrigger = card;
      openedByKeyboard = byKeyboard;
      const type = card.getAttribute('data-review-type') || 'image';
      const title = card.getAttribute('data-title') || 'Client review';
      const src = card.getAttribute('data-full') || '';

      if (type === 'video') {
        resetModalImage();
        modal.dataset.activeType = 'video';
        modalVideo.hidden = false;
        modalVideo.setAttribute('aria-label', `${title} from Easy Fit Alexandria`);
        modalVideo.src = src;
        modalVideo.load();
      } else {
        resetModalVideo();
        modal.dataset.activeType = 'image';
        modalImage.hidden = false;
        modalImage.src = src;
        modalImage.alt = `${title} from Easy Fit Alexandria`;
      }

      if (typeof modal.showModal === 'function') {
        modal.showModal();
      } else {
        modal.setAttribute('open', '');
      }
      closeButton?.focus();

      if (type === 'video' && modalVideo instanceof HTMLVideoElement) {
        const attempt = modalVideo.play();
        if (attempt && typeof attempt.catch === 'function') {
          attempt.catch(() => {});
        }
      }
    };

    const endDrag = (event) => {
      if (!isDragging) return;
      isDragging = false;
      if (activeScrollArea) activeScrollArea.classList.remove('is-dragging');
      if (activeScrollArea?.hasPointerCapture?.(event.pointerId)) {
        activeScrollArea.releasePointerCapture(event.pointerId);
      }

      if (hasMoved) {
        suppressClick = true;
        window.setTimeout(() => {
          suppressClick = false;
          hasMoved = false;
        }, suppressClickDelay);
      } else {
        hasMoved = false;
      }
      activeScrollArea = null;
      updateControls();
    };

    scrollAreas.forEach((scrollArea) => {
      scrollArea.addEventListener('pointerdown', (event) => {
        if (event.pointerType === 'mouse' && event.button !== 0) return;
        isDragging = true;
        hasMoved = false;
        activeScrollArea = scrollArea;
        startX = event.clientX;
        startScrollLeft = scrollArea.scrollLeft;
        scrollArea.classList.add('is-dragging');
        if (event.pointerType === 'mouse') scrollArea.setPointerCapture?.(event.pointerId);
      });

      scrollArea.addEventListener('pointermove', (event) => {
        if (!isDragging || activeScrollArea !== scrollArea) return;
        const delta = event.clientX - startX;
        if (Math.abs(delta) > dragThreshold) hasMoved = true;
        if (!hasMoved) return;

        if (event.pointerType === 'mouse') {
          event.preventDefault();
          scrollArea.scrollLeft = startScrollLeft - delta;
          updateControls();
        }
      });

      scrollArea.addEventListener('pointerup', endDrag);
      scrollArea.addEventListener('pointercancel', endDrag);
      scrollArea.addEventListener('pointerleave', endDrag);
      scrollArea.addEventListener('scroll', updateControls, { passive: true });
    });

    previousButton?.addEventListener('click', () => scrollReviews(-1));
    nextButton?.addEventListener('click', () => scrollReviews(1));

    /* Wheel-to-horizontal removed: let the browser handle scroll naturally. */

    section.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const card = target.closest('[data-review-card]');
      if (!card) return;

      if (suppressClick) {
        event.preventDefault();
        return;
      }

      openModal(card);
    });

    section.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' && event.key !== ' ') return;

      const target = event.target;
      if (!(target instanceof Element)) return;
      const card = target.closest('[data-review-card]');
      if (!card) return;

      event.preventDefault();
      openModal(card, true);
    });

    const loadPreviewVideo = (video) => {
      if (!(video instanceof HTMLVideoElement)) return;
      const src = video.dataset.src;
      if (!src || video.currentSrc) return;
      video.src = src;
    };

    const previewVideos = section.querySelectorAll('.review-preview-video');
    if ('IntersectionObserver' in window) {
      const previewObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            loadPreviewVideo(entry.target);
            previewObserver.unobserve(entry.target);
          });
        },
        { rootMargin: '360px 0px' }
      );

      previewVideos.forEach((video) => previewObserver.observe(video));
    } else {
      previewVideos.forEach(loadPreviewVideo);
    }

    closeButton?.addEventListener('click', closeModal);
    modal.addEventListener('click', (event) => {
      if (event.target === modal) closeModal();
    });
    modal.addEventListener('cancel', (event) => {
      event.preventDefault();
      closeModal();
    });

    updateControls();
  })();
</script>
