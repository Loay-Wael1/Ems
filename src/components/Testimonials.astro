          <img src="/posters/studio-3.jpg" class="video-poster-img" alt="فيديو تفعيل عضلات الجسم" loading="lazy" width="360" height="640" />
          <div class="video-overlay">
            <span class="video-play-btn">
              <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </div>
        </div>
        <div class="video-card-info">
          <h3 class="video-card-title">تفعيل العضلات</h3>
          <span class="video-card-subtitle en">Studio media · 0:24</span>
        </div>
      </button>
      
    </div>
  </div>
</section>

<!-- Accessible Video Modal Dialog -->
<dialog class="video-modal" id="videoModal" aria-label="مشاهدة فيديو تجارب العملاء">
  <div class="modal-content-shell">
    <div class="modal-header-top">
      <button class="modal-close-button" type="button" aria-label="إغلاق الفيديو">×</button>
      <span class="modal-title-text" id="modalTitle">Easy Fit Alexandria</span>
    </div>
    <div class="modal-player-container">
      <video class="modal-video-tag" id="modalVideo" controls playsinline></video>
    </div>
  </div>
</dialog>

<script>
  const modal = document.getElementById('videoModal') as HTMLDialogElement | null;
  const modalVideo = document.getElementById('modalVideo') as HTMLVideoElement | null;
  const modalTitle = document.getElementById('modalTitle');
  const closeButton = modal?.querySelector('.modal-close-button');
  let lastFocusedElement: HTMLElement | null = null;

  const resetVideo = () => {
    if (modalVideo) {
      modalVideo.pause();
      modalVideo.currentTime = 0;
      modalVideo.removeAttribute('src');
      modalVideo.load();
    }
  };

  const closeModal = () => {
    if (modal?.open) {
      modal.close();
    }
  };

  document.querySelectorAll('.video-card').forEach((card) => {
    card.addEventListener('click', () => {
      if (!modal || !modalVideo || !modalTitle) return;

      const videoSrc = card.getAttribute('data-video');
      const title = card.getAttribute('data-title') || 'Easy Fit Alexandria';

      if (!videoSrc) return;

      lastFocusedElement = document.activeElement as HTMLElement;
      resetVideo();

      modalTitle.textContent = title;
      modalVideo.src = videoSrc;
      modalVideo.setAttribute('aria-label', title);
      
      modal.showModal();
      document.body.classList.add('modal-open');
      
      if (closeButton instanceof HTMLElement) {
        closeButton.focus();
      }

      const playPromise = modalVideo.play();
      if (playPromise) {
        playPromise.catch(() => {
          // Fallback if autoplay is blocked
        });
      }
    });
  });

  closeButton?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });

  modal?.addEventListener('close', () => {
    resetVideo();
    document.body.classList.remove('modal-open');
    if (lastFocusedElement) {
      lastFocusedElement.focus();
    }
  });
</script>
