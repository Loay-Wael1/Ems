---
const whatsappUrl = 'https://wa.me/201124799978';
const telUrl = 'tel:+201124799978';
const instagramUrl = 'https://instagram.com/ems.easyfit.alexandria?igsh=MWV1NDlkcG1wc3dnYw==';
const facebookUrl = 'https://www.facebook.com/ems.easyfit.alexandria/?ref=NONE_xav_ig_profile_page_web#';

const studios = [
  {
    name: 'Smouha',
    address: "Delta Life Administrative Towers, Madinet El Mar'a Hospital Street, behind Motager Mall."
  },
  {
    name: 'Ganaklis',
    address: 'El Zeraeyeen Towers, Abu Qir Street, in front of El Sallab.'
  }
];
---

<section class="section-padding locations-section" id="locations" aria-labelledby="locations-title">
  <div class="container">
    <div class="section-head center reveal-on-scroll">
      <p class="eyebrow">STUDIOS</p>
      <h2 id="locations-title" class="section-title">Two Alexandria studios. One focused EMS experience.</h2>
      <p class="section-intro">
        Choose the branch that works for your day and message us to book your trial session.
      </p>
    </div>

    <div class="location-grid">
      {
        studios.map((studio, index) => (
          <article class="location-card reveal-on-scroll" style={`--card-index:${index}`}>
            <span class="location-label">Easy Fit Studio</span>
            <h3>{studio.name}</h3>
            <p>{studio.address}</p>
            <div class="location-actions">
              <a class="btn btn-primary" href={whatsappUrl} target="_blank" rel="noreferrer">WhatsApp</a>
              <a class="btn btn-ghost" href={telUrl}>Call</a>
              <a class="btn btn-link" href={instagramUrl} target="_blank" rel="noreferrer">Instagram</a>
              <a class="btn btn-link" href={facebookUrl} target="_blank" rel="noreferrer">Facebook</a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
