---
import smouhaImage from '../../smouha.webp';
import ganaklisImage from '../../چناكليس.jpg';

const smouhaMessage = encodeURIComponent(
  'Hello Easy Fit Alexandria, I came from the website and would like to ask about booking an EMS trial session at the Smouha branch.'
);
const ganaklisMessage = encodeURIComponent(
  'Hello Easy Fit Alexandria, I came from the website and would like to ask about booking an EMS trial session at the Ganaklis branch.'
);

const studios = [
  {
    name: 'Smouha',
    address: 'Delta Life Administrative Towers, behind Motager Mall, first floor, Studio 7B.',
    image: smouhaImage,
    whatsapp: `https://wa.me/201124799978?text=${smouhaMessage}`,
    mobileCall: 'tel:+201124799978',
    landlineCall: 'tel:034238908',
    map: 'https://maps.app.goo.gl/FvXUjLWDzwrzMSg99?g_st=ic'
  },
  {
    name: 'Ganaklis',
    address: 'El Zeraeyeen Towers, ground floor, Abu Qir Street, in front of El Sallab.',
    image: ganaklisImage,
    whatsapp: `https://wa.me/201121112737?text=${ganaklisMessage}`,
    mobileCall: 'tel:+201121112737',
    landlineCall: 'tel:035708750',
    map: 'https://maps.app.goo.gl/v9XFmCjmfcxYoo6g7?g_st=ic'
  }
];
---

<section class="section-padding locations-section" id="locations" aria-labelledby="locations-title">
  <div class="container">
    <div class="section-head center reveal-on-scroll">
      <h2 id="locations-title" class="section-title">Our Branches</h2>
      <p class="section-intro">
        Smouha or Ganaklis — choose the branch that fits your day.
      </p>
    </div>

    <div class="location-grid">
      {
        studios.map((studio, index) => (
          <article class="location-card reveal-on-scroll" style={`--card-index:${index}`}>
            <div class="location-image-wrap">
              <img
                src={studio.image.src}
                width={studio.image.width}
                height={studio.image.height}
                alt={`${studio.name} Easy Fit Alexandria studio visual`}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="location-content">
              <h3>{studio.name}</h3>
              <p>{studio.address}</p>
              <div class="location-actions">
                <a class="btn btn-primary location-action-button" href={studio.whatsapp} target="_blank" rel="noopener noreferrer">
                  <svg class="location-action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M12 3.1a8.7 8.7 0 0 0-7.4 13.2L3.5 20.8l4.6-1.2A8.7 8.7 0 1 0 12 3.1Zm0 1.8a6.9 6.9 0 0 1 5.9 10.5 6.9 6.9 0 0 1-8.1 2.7l-.4-.2-2.9.8.8-2.8-.2-.4A6.9 6.9 0 0 1 12 4.9Zm-3 3.6c-.2 0-.5.1-.7.4-.3.3-.9.9-.9 2.1 0 1.2.9 2.4 1 2.6.1.2 1.7 2.8 4.2 3.8 2.1.8 2.5.6 3 .6.5 0 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2-.1-.1-.2-.2-.5-.3l-1.7-.8c-.2-.1-.4-.1-.6.1-.2.3-.7.8-.8 1-.1.2-.3.2-.5.1-.3-.1-1.1-.4-2-1.2-.7-.7-1.2-1.5-1.4-1.7-.1-.3 0-.4.1-.5l.4-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5l-.8-1.8c-.2-.4-.4-.4-.6-.4H9Z" fill="currentColor" />
                  </svg>
                  <span>WhatsApp</span>
                </a>
                <a class="btn btn-ghost location-action-button" href={studio.mobileCall}>
                  <svg class="location-action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M8.3 2.8h7.4c.9 0 1.7.8 1.7 1.7v15c0 .9-.8 1.7-1.7 1.7H8.3c-.9 0-1.7-.8-1.7-1.7v-15c0-.9.8-1.7 1.7-1.7Zm0 1.8v14.8h7.4V4.6H8.3Zm2.3 12.8h2.8v1.2h-2.8v-1.2Z" fill="currentColor" />
                  </svg>
                  <span>Call Mobile</span>
                </a>
                <a class="btn btn-ghost location-action-button" href={studio.landlineCall}>
                  <svg class="location-action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M7.3 4.2h9.4c1.1 0 2 .9 2 2v3.2c0 .7-.5 1.2-1.2 1.2h-2.1c-.7 0-1.2-.5-1.2-1.2V8.2H9.8v1.2c0 .7-.5 1.2-1.2 1.2H6.5c-.7 0-1.2-.5-1.2-1.2V6.2c0-1.1.9-2 2-2Zm2 6.8h5.4l3 6.8c.2.5-.1 1-.6 1H6.9c-.5 0-.8-.5-.6-1l3-6.8Zm1.2 1.8-.7 1.6h4.4l-.7-1.6h-3Zm-1.4 3.2-.5 1.2h6.8l-.5-1.2H9.1Z" fill="currentColor" />
                  </svg>
                  <span>Call Landline</span>
                </a>
                <a class="btn btn-ghost location-action-button" href={studio.map} target="_blank" rel="noopener noreferrer">
                  <svg class="location-action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M12 2.8a6.7 6.7 0 0 0-6.7 6.7c0 4.8 5.8 11.2 6.1 11.5.3.3.8.3 1.1 0 .3-.3 6.1-6.7 6.1-11.5A6.7 6.7 0 0 0 12 2.8Zm0 1.8a4.9 4.9 0 0 1 4.9 4.9c0 3.1-3.2 7.4-4.9 9.4-1.7-2-4.9-6.3-4.9-9.4A4.9 4.9 0 0 1 12 4.6Zm0 2.6a2.4 2.4 0 1 0 0 4.8 2.4 2.4 0 0 0 0-4.8Zm0 1.7a.7.7 0 1 1 0 1.4.7.7 0 0 1 0-1.4Z" fill="currentColor" />
                  </svg>
                  <span>View on Map</span>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
