---
import smouhaImage from '../../smouha.webp';
import ganaklisImage from '../../چناكليس.jpg';

const studios = [
  {
    name: 'Smouha',
    address: 'Delta Life Administrative Towers, behind Motager Mall, first floor, Studio 7B.',
    image: smouhaImage,
    whatsapp: 'https://wa.me/201124799978?text=Hello%20Easy%20Fit%20Alexandria%2C%20I%20came%20from%20the%20website%20and%20would%20like%20to%20ask%20about%20booking%20an%20EMS%20trial%20session%20at%20the%20Smouha%20branch.',
    mobileCall: 'tel:+201124799978',
    landlineCall: 'tel:034238908',
    map: 'https://maps.app.goo.gl/FvXUjLWDzwrzMSg99?g_st=ic'
  },
  {
    name: 'Ganaklis',
    address: 'El Zeraeyeen Towers, ground floor, Abu Qir Street, in front of El Sallab.',
    image: ganaklisImage,
    whatsapp: 'https://wa.me/201121112737?text=Hello%20Easy%20Fit%20Alexandria%2C%20I%20came%20from%20the%20website%20and%20would%20like%20to%20ask%20about%20booking%20an%20EMS%20trial%20session%20at%20the%20Ganaklis%20branch.',
    mobileCall: 'tel:+201121112737',
    landlineCall: 'tel:035708750',
    map: 'https://maps.app.goo.gl/v9XFmCjmfcxYoo6g7?g_st=ic'
  }
];
---

<section class="section-padding locations-section" id="locations" aria-labelledby="locations-title">
  <div class="container">
    <div class="section-head center reveal-on-scroll">
      <h2 id="locations-title" class="section-title">Our Branches</h2>
      <p class="section-intro">
        Smouha or Ganaklis — choose the branch that fits your day.
      </p>
    </div>

    <div class="location-grid">
      {
        studios.map((studio, index) => (
          <article class="location-card reveal-on-scroll" style={`--card-index:${index}`}>
            <div class="location-image-wrap">
              <img
                src={studio.image.src}
                width={studio.image.width}
                height={studio.image.height}
                alt={`${studio.name} Easy Fit Alexandria studio visual`}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="location-content">
              <h3>{studio.name}</h3>
              <p>{studio.address}</p>
              <div class="location-actions">
                <a class="btn btn-primary" href={studio.whatsapp} target="_blank" rel="noopener noreferrer">WhatsApp</a>
                <a class="btn btn-ghost" href={studio.mobileCall}>Call Mobile</a>
                <a class="btn btn-ghost" href={studio.landlineCall}>Call Landline</a>
                <a class="btn btn-link" href={studio.map} target="_blank" rel="noopener noreferrer">View on Map</a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
