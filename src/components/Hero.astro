---
const heroVideoUrl = '/videos/ems-experience.mp4';
const mobileHeroVideoUrl = '/videos/ems-experience-reel-v2.mp4';
const heroReelVideoUrl = '/videos/ems-experience-reel-v2.mp4';
const heroVideoPoster = '/videos/ems-experience-poster.webp';
const impactBadges = [
  { label: 'Smart 20-Minute EMS', href: '#what-is-ems' },
  { label: 'Expert Coaches & Nutrition', href: '#expert-coaches' },
  { label: 'Client Reviews', href: '#testimonials' },
  { label: 'Our Branches', href: '#locations' }
];
---

<section class="hero-section" aria-labelledby="hero-title">
  <div class="hero-media" aria-hidden="true">
    <video
      class="hero-bg-video"
      data-src={mobileHeroVideoUrl}
      autoplay
      muted
      loop
      playsinline
      preload="none"
      poster={heroVideoPoster}
    ></video>
    <div class="hero-static-overlay"></div>
    <div class="hero-glow hero-glow-primary"></div>
    <div class="hero-glow hero-glow-secondary"></div>
  </div>

  <div class="container hero-grid">
    <div class="hero-copy">
      <h1 id="hero-title" class="hero-title reveal-on-scroll">
        Train smarter. <span>Transform faster.</span>
      </h1>
      <p class="hero-description reveal-on-scroll reveal-delay-2">
        20-minute EMS sessions designed to activate deep muscle fibers, save time, and help you
        build a stronger, leaner body with coach-guided intensity.
      </p>

      <div class="hero-actions reveal-on-scroll reveal-delay-3">
        <a class="btn btn-primary btn-large" href="#booking-form">
          Book Your Trial Session
        </a>
        <a class="btn btn-ghost btn-large" href="#results">See Transformations</a>
      </div>

      <ul class="hero-badges reveal-on-scroll reveal-delay-4" aria-label="Easy Fit highlights">
        {
          impactBadges.map((badge) => (
            <li>
              {badge.href ? (
                <a href={badge.href}>{badge.label}</a>
              ) : (
                <span>{badge.label}</span>
              )}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="hero-visual reveal-on-scroll reveal-delay-3" aria-label="Easy Fit EMS experience preview">
      <div class="hero-reel-card">
        <div class="hero-reel-top">
          <span>EMS Experience</span>
        </div>
        <video
          class="hero-reel-video"
          data-src={heroReelVideoUrl}
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          poster={heroVideoPoster}
          aria-label="Easy Fit EMS training preview"
        ></video>
        <p>See how EMS activates your muscles</p>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const mobileMedia = window.matchMedia('(max-width: 759px)');
    const desktopMedia = window.matchMedia('(min-width: 760px)');
    const bgVideo = document.querySelector('.hero-bg-video');
    const reelVideo = document.querySelector('.hero-reel-video');

    const handleBgVideo = () => {
      if (!(bgVideo instanceof HTMLVideoElement)) return;

      if (mobileMedia.matches) {
        const src = bgVideo.dataset.src;
        if (src && !bgVideo.currentSrc) {
          bgVideo.src = src;
          bgVideo.load();
        }
        bgVideo.muted = true;
        bgVideo.defaultMuted = true;
        bgVideo.playsInline = true;
        const attempt = bgVideo.play();
        if (attempt && typeof attempt.catch === 'function') {
          attempt.catch(() => {});
        }
      } else {
        bgVideo.pause();
        bgVideo.removeAttribute('src');
        bgVideo.load();
      }
    };

    const playHeroReel = () => {
      if (!desktopMedia.matches) return;
      if (!(reelVideo instanceof HTMLVideoElement)) return;

      const videoSrc = reelVideo.dataset.src;
      if (videoSrc && !reelVideo.currentSrc) {
        reelVideo.src = videoSrc;
        reelVideo.load();
      }

      reelVideo.muted = true;
      reelVideo.defaultMuted = true;
      reelVideo.playsInline = true;

      const attempt = reelVideo.play();
      if (attempt && typeof attempt.catch === 'function') {
        attempt.catch(() => {});
      }
    };

    const run = () => {
      handleBgVideo();
      playHeroReel();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run, { once: true });
    } else {
      run();
    }

    mobileMedia.addEventListener('change', run);
    desktopMedia.addEventListener('change', run);
    window.addEventListener('pageshow', run);
  })();
</script>
