---
const whatsappUrl = 'https://wa.me/201124799978';
const heroVideoUrl = '/videos/ems-experience.mp4';
const heroReelVideoUrl = '/videos/ems-experience-reel.mp4';
const heroVideoPoster = '/videos/ems-experience-poster.webp';
const impactBadges = ['20 Min Session', 'Coach Guided', 'Two Alexandria Studios', 'EMS Technology'];
---

<section class="hero-section" aria-labelledby="hero-title">
  <div class="hero-media" aria-hidden="true">
    <video
      class="hero-bg-video"
      src={heroVideoUrl}
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={heroVideoPoster}
    ></video>
    <div class="hero-static-overlay"></div>
    <div class="hero-glow hero-glow-cyan"></div>
    <div class="hero-glow hero-glow-pink"></div>
  </div>

  <div class="container hero-grid">
    <div class="hero-copy">
      <h1 id="hero-title" class="hero-title reveal-on-scroll">
        Train smarter. <span>Transform faster.</span>
      </h1>
      <p class="hero-description reveal-on-scroll reveal-delay-2">
        20-minute EMS sessions designed to activate deep muscle fibers, save time, and help you
        build a stronger, leaner body with coach-guided intensity.
      </p>

      <div class="hero-actions reveal-on-scroll reveal-delay-3">
        <a class="btn btn-primary btn-large" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
          Book Your Trial Session
        </a>
        <a class="btn btn-ghost btn-large" href="#results">See Transformations</a>
      </div>

      <ul class="hero-badges reveal-on-scroll reveal-delay-4" aria-label="Easy Fit highlights">
        {impactBadges.map((badge) => <li>{badge}</li>)}
      </ul>
    </div>

    <div class="hero-visual reveal-on-scroll reveal-delay-3" aria-label="Easy Fit EMS experience preview">
      <div class="hero-reel-card">
        <div class="hero-reel-top">
          <span>EMS Experience</span>
        </div>
        <video
          class="hero-reel-video"
          data-src={heroReelVideoUrl}
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          poster={heroVideoPoster}
          aria-label="Easy Fit EMS training preview"
        ></video>
        <p>See how EMS activates your muscles</p>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const desktopMedia = window.matchMedia('(min-width: 760px)');

    const playHeroReel = () => {
      if (!desktopMedia.matches) return;

      const video = document.querySelector('.hero-reel-video');
      if (!(video instanceof HTMLVideoElement)) return;

      const videoSrc = video.dataset.src;
      if (videoSrc && !video.currentSrc) {
        video.src = videoSrc;
        video.load();
      }

      video.muted = true;
      video.defaultMuted = true;
      video.playsInline = true;

      const attempt = video.play();
      if (attempt && typeof attempt.catch === 'function') {
        attempt.catch(() => {});
      }
    };

    const run = () => {
      playHeroReel();
      window.setTimeout(playHeroReel, 150);
      window.setTimeout(playHeroReel, 500);
      window.setTimeout(playHeroReel, 1000);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run, { once: true });
    } else {
      run();
    }

    window.addEventListener('pageshow', playHeroReel);

    ['pointerdown', 'keydown'].forEach((eventName) => {
      window.addEventListener(eventName, playHeroReel, {
        once: true,
        passive: true
      });
    });
  })();
</script>
