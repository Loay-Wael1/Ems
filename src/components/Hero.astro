---
---
<section class="hero-section" id="hero" aria-labelledby="hero-title">
  <!-- Subtle back pulse effect -->
  <div class="hero-bg">
    <div class="hero-pulse-effect" aria-hidden="true"></div>
  </div>

  <div class="container hero-grid">
    <!-- Visual Brand Panel (Left on Desktop, Right in RTL flow, let's keep it clean) -->
    <div class="hero-visual">
      <div class="hero-brand-panel">
        <div class="panel-header">
          <span class="panel-header-title">EMS ACTIVATION</span>
          <span class="en">READY</span>
        </div>
        
        <!-- Timer Motif -->
        <div class="timer-motif">20:00</div>

        <!-- Clean, respectfully framed logo without cheap white circles -->
        <div class="panel-logo-container">
          <img src="/logo-transparent.png" class="panel-logo" alt="Easy Fit Alexandria logo" width="120" height="120" />
        </div>

        <!-- Scanning Pulse Line -->
        <div class="panel-line-pulse" aria-hidden="true">
          <div class="panel-pulse-indicator"></div>
        </div>

        <!-- Panel Metrics -->
        <div class="panel-stats">
          <div class="stat-box">
            <span class="stat-label">Session</span>
            <span class="stat-value">Full Body</span>
          </div>
          <div class="stat-box">
            <span class="stat-label">Intensity</span>
            <span class="stat-value en-val">Custom</span>
          </div>
          <div class="stat-box">
            <span class="stat-label">Branches</span>
            <span class="stat-value">2 Branches</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Copy Content -->
    <div class="hero-content">
      <p class="hero-eyebrow">Alexandria’s 1st EMS Studio</p>
      
      <h1 id="hero-title" class="hero-title">
        <span>٢٠ دقيقة.</span>
        <span>جسمك كله يشتغل.</span>
        <span>وإنت تحت متابعة كوتش.</span>
      </h1>
      
      <p class="hero-description">
        مش كل الناس عندها وقت للجيم كل يوم، ومش كل جسم محتاج نفس نوع التمرين. 
        في Easy Fit، جلسة EMS قصيرة ومركزة بتتظبط حسب هدفك — خسارة دهون، شد جسم، زيادة عضلات، أو رجوع محسوب للتمرين.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="https://wa.me/201124799978" target="_blank" rel="noopener">
          احجز جلستك التجريبية
        </a>
        <a class="btn btn-secondary" href="#testimonials">
          شوف الناس قالت إيه
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Proof Claim Band -->
<section class="claim-band" aria-label="أرقام تهمك عن تمرين Easy Fit">
  <div class="container claim-grid">
    <div class="claim-item">
      <div class="claim-title en">20 Min EMS</div>
      <div class="claim-desc">تعادل ساعتين تمرين في الجيم التقليدي</div>
    </div>
    <div class="claim-item">
      <div class="claim-title">1st EMS Studio</div>
      <div class="claim-desc">أول ستوديو متخصص في الإسكندرية</div>
    </div>
    <div class="claim-item">
      <div class="claim-title">Coaches & Nutrition</div>
      <div class="claim-desc">متابعة تمرين وتغذية متخصصة ومستمرة</div>
    </div>
  </div>
</section>
