---
import { siteContent, type Locale } from '../i18n/content';

interface Props {
  copy?: (typeof siteContent)[Locale]['hero'];
  locale?: Locale;
}

const { copy = siteContent.en.hero } = Astro.props;

const mobileHeroVideoUrl = '/videos/ems-experience-reel-v2-mobile.mp4';
const mobileHeroPosterUrl = '/videos/ems-experience-reel-v2-poster.webp';
const impactBadges = copy.badges;
---

<section class="hero-section" aria-labelledby="hero-title">
  <div class="hero-media" aria-hidden="true">
    <video
      class="hero-bg-video"
      data-src={mobileHeroVideoUrl}
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster={mobileHeroPosterUrl}
    ></video>
    <div class="hero-static-overlay"></div>
    <div class="hero-glow hero-glow-primary"></div>
    <div class="hero-glow hero-glow-secondary"></div>
  </div>

  <div class="container hero-grid">
    <div class="hero-copy">
      <h1 id="hero-title" class="hero-title reveal-on-scroll">
        {copy.title} <span>{copy.titleAccent}</span>
      </h1>
      <p class="hero-description reveal-on-scroll reveal-delay-2">
        {copy.description}
      </p>

      <div class="hero-actions reveal-on-scroll reveal-delay-3">
        <a class="btn btn-primary btn-large" href="#booking-form">
          {copy.primaryCta}
        </a>
        <a class="btn btn-ghost btn-large" href="#results">{copy.secondaryCta}</a>
      </div>

      <ul class="hero-badges reveal-on-scroll reveal-delay-4" aria-label={copy.badgesAriaLabel}>
        {
          impactBadges.map((badge) => (
            <li>
              {badge.href ? (
                <a href={badge.href}>{badge.label}</a>
              ) : (
                <span>{badge.label}</span>
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<script>
  (() => {
    const mobileMedia = window.matchMedia('(max-width: 759px)');
    const bgVideo = document.querySelector('.hero-bg-video');

    const handleBgVideo = () => {
      if (!(bgVideo instanceof HTMLVideoElement)) return;

      if (mobileMedia.matches) {
        const src = bgVideo.dataset.src;
        bgVideo.preload = 'auto';
        bgVideo.muted = true;
        bgVideo.defaultMuted = true;
        bgVideo.playsInline = true;

        if (src && bgVideo.getAttribute('src') !== src) {
          bgVideo.src = src;
          bgVideo.load();
        }

        const markReady = () => bgVideo.classList.add('is-ready');
        bgVideo.addEventListener('loadeddata', markReady, { once: true });
        bgVideo.addEventListener('canplay', markReady, { once: true });
        bgVideo.addEventListener('playing', markReady, { once: true });

        const attempt = bgVideo.play();
        if (attempt && typeof attempt.catch === 'function') {
          attempt.catch(() => {});
        }
      } else {
        bgVideo.pause();
        bgVideo.removeAttribute('src');
        bgVideo.classList.remove('is-ready');
        bgVideo.load();
      }
    };

    const run = () => {
      handleBgVideo();
    };

    run();

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run, { once: true });
    }

    if (typeof mobileMedia.addEventListener === 'function') {
      mobileMedia.addEventListener('change', run);
    } else {
      mobileMedia.addListener(run);
    }
    window.addEventListener('pageshow', run);
  })();
</script>
