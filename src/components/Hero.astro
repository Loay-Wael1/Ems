---
---
<section class="hero-section" id="hero" aria-labelledby="hero-title">
  <div class="container hero-grid">
    <!-- Visual side: Premium, minimal typographic timer and raw logo connected by a dotted wave -->
    <div class="hero-visual">
      <div class="hero-editorial-panel">
        <!-- Subtle dotted wave motif flowing from logo area to timer -->
        <svg class="hero-pulse-wave" viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="150" cy="150" r="130" stroke="rgba(6, 14, 29, 0.06)" stroke-width="1" stroke-dasharray="4 6" />
          <circle cx="150" cy="150" r="100" stroke="rgba(6, 14, 29, 0.04)" stroke-width="1.5" />
          <path d="M 60,150 C 120,70 180,230 240,150" stroke="var(--teal)" stroke-opacity="0.25" stroke-width="1.5" stroke-dasharray="2 3" stroke-linecap="round" />
        </svg>

        <!-- Timer Display -->
        <div class="hero-timer-display">20:00</div>
        
        <!-- Original logo clean, official, and untouched (no circle wrapping or fake glow) -->
        <div class="hero-logo-frame">
          <img src="/logo-transparent.png" class="hero-logo-img" alt="شعار Easy Fit" width="140" height="140" />
        </div>
      </div>
    </div>

    <!-- Text content side -->
    <div class="hero-content">
      <p class="hero-eyebrow">Alexandria’s 1st EMS Studio</p>
      
      <h1 id="hero-title" class="hero-title">
        <span>٢٠ دقيقة.</span>
        <span>جسمك كله يشتغل.</span>
        <span>وإنت تحت متابعة كوتش.</span>
      </h1>
      
      <p class="hero-description">
        مش كل الناس عندها وقت للجيم كل يوم، ومش كل جسم محتاج نفس نوع التمرين. 
        في Easy Fit، جلسة EMS قصيرة ومركزة بتتظبط حسب هدفك — خسارة دهون، شد جسم، زيادة عضلات، أو رجوع محسوب للتمرين.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="https://wa.me/201124799978" target="_blank" rel="noopener">
          احجز جلستك التجريبية
        </a>
        <a class="btn btn-secondary" href="#testimonials">
          شوف الناس قالت إيه
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Proof Claim Band -->
<section class="claim-band" aria-label="أرقام تهمك عن تمرين Easy Fit">
  <div class="container claim-grid">
    <div class="claim-item">
      <div class="claim-title en">20 Min EMS</div>
      <div class="claim-desc">تعادل ساعتين تمرين في الجيم</div>
    </div>
    <div class="claim-item">
      <div class="claim-title">1st EMS Studio</div>
      <div class="claim-desc">أول ستوديو متخصص في الإسكندرية</div>
    </div>
    <div class="claim-item">
      <div class="claim-title">Coaches & Nutrition</div>
      <div class="claim-desc">متابعة تمرين وتغذية متخصصة</div>
    </div>
  </div>
</section>
