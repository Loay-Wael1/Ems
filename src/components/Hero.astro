---
---
<section class="hero-section" id="hero" aria-labelledby="hero-title">
  <div class="container hero-grid">
    <!-- Text content side (on the RIGHT for RTL reading flow) -->
    <div class="hero-content">
      <!-- Clean untouched logo stamp above copy -->
      <div class="hero-logo-stamp">
        <img src="/logo-transparent.png" alt="شعار Easy Fit" width="48" height="48" />
      </div>

      <p class="hero-eyebrow">Alexandria’s 1st EMS Studio</p>
      
      <h1 id="hero-title" class="hero-title">
        <span>جسمك يشتغل بذكاء.</span>
        <span>في جلسة قصيرة ومتابَعة.</span>
      </h1>
      
      <p class="hero-description">
        مش كل الناس عندها وقت للجيم كل يوم، ومش كل جسم محتاج نفس نوع التمرين. 
        في Easy Fit، جلسة EMS بتتظبط حسب هدفك — خسارة دهون، شد جسم، زيادة عضلات، أو رجوع محسوب للتمرين.
      </p>

      <!-- Support Badge -->
      <div class="hero-support-badge en">20 Min EMS = 2 Hours in Gym</div>

      <div class="hero-actions">
        <a class="btn btn-primary" href="https://wa.me/201124799978" target="_blank" rel="noopener">
          احجز جلستك التجريبية
        </a>
        <a class="btn btn-secondary" href="#testimonials">
          شوف الناس قالت إيه
        </a>
      </div>
    </div>

    <!-- Visual side: Eager loaded editorial image card (on the LEFT for RTL reading flow) -->
    <div class="hero-visual">
      <div class="hero-image-wrapper">
        <picture>
          <source srcset="/hero.webp" type="image/webp" />
          <img 
            src="/hero.webp" 
            alt="جلسة تمرين EMS في ستوديو Easy Fit Alexandria" 
            class="hero-image-tag" 
            width="420" 
            height="525" 
            loading="eager" 
            fetchpriority="high" 
            decoding="async" 
          />
        </picture>
        <div class="hero-image-badge">EMS Session</div>
      </div>
    </div>
  </div>
</section>

<!-- Proof Claim Band -->
<section class="claim-band" aria-label="ميزات ستوديو Easy Fit">
  <div class="container claim-grid">
    <div class="claim-item">
      <div class="claim-title">أول EMS Studio في إسكندرية</div>
      <div class="claim-desc">أول ستوديو متخصص بمعدات معتمدة</div>
    </div>
    <div class="claim-item">
      <div class="claim-title">مدربين وخبراء تغذية</div>
      <div class="claim-desc">متابعة مخصصة ومستمرة لتحقيق أهدافك</div>
    </div>
    <div class="claim-item">
      <div class="claim-title">فرعين: سموحة وجناكليس</div>
      <div class="claim-desc">اختر الفرع الأقرب وابدأ التمرين بسهولة</div>
    </div>
  </div>
</section>

<style>
  .hero-support-badge {
    display: inline-block;
    font-family: var(--font-en);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--teal);
    letter-spacing: 0.5px;
    margin-bottom: 24px;
    text-transform: uppercase;
  }
</style>
