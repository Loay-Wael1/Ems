---
const whatsappUrl = 'https://wa.me/201124799978';
const impactBadges = ['20 Min Session', 'Coach Guided', 'Two Alexandria Studios', 'EMS Technology'];
---

<section class="hero-section" aria-labelledby="hero-title">
  <div class="hero-media" aria-hidden="true">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata" poster="/hero-poster.webp">
      <source src="/hero-video.mp4" type="video/mp4" />
    </video>
    <div class="hero-video-overlay"></div>
    <div class="hero-glow hero-glow-cyan"></div>
    <div class="hero-glow hero-glow-pink"></div>
  </div>

  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow hero-eyebrow reveal-on-scroll">Alexandria's 1st EMS Studio</p>
      <h1 id="hero-title" class="hero-title reveal-on-scroll reveal-delay-1">
        Train smarter. <span>Transform faster.</span>
      </h1>
      <p class="hero-description reveal-on-scroll reveal-delay-2">
        20-minute EMS sessions designed to activate deep muscle fibers, save time, and help you
        build a stronger, leaner body with coach-guided intensity.
      </p>

      <div class="hero-actions reveal-on-scroll reveal-delay-3">
        <a class="btn btn-primary btn-large" href={whatsappUrl} target="_blank" rel="noreferrer">
          Book Your Trial Session
        </a>
        <a class="btn btn-ghost btn-large" href="#results">See Transformations</a>
      </div>

      <ul class="hero-badges reveal-on-scroll reveal-delay-4" aria-label="Easy Fit highlights">
        {impactBadges.map((badge) => <li>{badge}</li>)}
      </ul>
    </div>

    <div class="hero-visual reveal-on-scroll reveal-delay-3" aria-label="20 minute full-body EMS workout">
      <div class="pulse-card">
        <div class="pulse-card-top">
          <span>EMS ACTIVE</span>
          <span class="live-dot">LIVE</span>
        </div>
        <div class="timer-orb">
          <span class="timer-value">20</span>
          <span class="timer-unit">min</span>
        </div>
        <p>Full-body EMS workout</p>
        <div class="pulse-line" aria-hidden="true"></div>
        <span class="micro-copy">Deep activation. Less wasted time.</span>
      </div>
    </div>
  </div>
</section>
