---
const steps = [
  {
    title: 'Consultation',
    text: 'We understand your goal, fitness level, schedule, and any limitations before the first pulse.'
  },
  {
    title: 'EMS Suit Setup',
    text: 'Your coach fits the suit and calibrates the muscle zones for a precise, comfortable start.'
  },
  {
    title: '20-Min Guided Workout',
    text: 'You move through a focused session while intensity is adjusted in real time.'
  },
  {
    title: 'Progress Plan',
    text: 'We map your next sessions with coaching and nutrition support so the work keeps moving.'
  }
];
---

<section class="section-padding process-section" id="process" aria-labelledby="process-title">
  <div class="container">
    <div class="section-head center reveal-on-scroll">
      <h2 id="process-title" class="section-title">Your first session, without the guesswork.</h2>
    </div>

    <div class="process-timeline">
      {
        steps.map((step, index) => (
          <article class="process-step reveal-on-scroll" style={`--card-index:${index}`}>
            <span class="step-number">{String(index + 1).padStart(2, '0')}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
