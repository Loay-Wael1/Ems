---
import { siteContent, type Locale } from '../i18n/content';

interface Props {
  copy?: (typeof siteContent)[Locale]['coaches'];
  locale?: Locale;
}

const { copy = siteContent.en.coaches } = Astro.props;
const trustCards = copy.trustCards;

const coachVideoSources = [
  {
    src: '/videos/coaches/coach-sohaila-ems.mp4'
  },
  {
    src: '/videos/coaches/coach-arwa-ems-1.mp4'
  },
  {
    src: '/videos/coaches/coach-train-smarter.mp4'
  }
];

const coachVideos = coachVideoSources.map((video, index) => ({
  ...video,
  ...copy.videos[index]
}));

const [featuredVideo, ...supportingVideos] = coachVideos;
---

<section class="section-padding expert-section" id="expert-coaches" aria-labelledby="expert-title">
  <div class="container expert-shell">
    <div class="expert-content-column">
      <div class="section-head expert-copy reveal-on-scroll">
        <span class="section-kicker">{copy.kicker}</span>
        <h2 id="expert-title" class="section-title">
          {copy.title}
        </h2>
        <p class="section-intro">
          {copy.intro}
        </p>
      </div>

      <div class="coach-trust-grid">
        {
          trustCards.map((card, index) => (
            <article class="coach-trust-card reveal-on-scroll" style={`--card-index:${index}`}>
              <span class="coach-trust-number">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <h3>{card.title}</h3>
                <p>{card.text}</p>
              </div>
            </article>
          ))
        }
      </div>

      <p class="expert-privacy-note reveal-on-scroll">
        {copy.privacyNote}
      </p>
    </div>

    <div class="expert-media reveal-on-scroll reveal-delay-1">
      <article class="coach-video-card coach-video-card-featured">
        <div class="coach-video-frame">
          <video
            class="coach-feature-video"
            data-src={featuredVideo.src}
            controls
            playsinline
            preload="none"
            aria-label={featuredVideo.ariaLabel}
          ></video>
        </div>
        <div class="coach-video-caption">
          <span>{featuredVideo.label}</span>
          {copy.featuredDetail && <strong>{copy.featuredDetail}</strong>}
        </div>
      </article>

      {
        supportingVideos.length > 0 && (
          <div class="coach-video-grid" aria-label={copy.moreVideosLabel}>
            {supportingVideos.map((video) => (
              <article class="coach-video-card coach-video-card-small">
                <div class="coach-video-frame">
                  <video
                    data-src={video.src}
                    controls
                    playsinline
                    preload="none"
                    aria-label={video.ariaLabel}
                  ></video>
                </div>
                <div class="coach-video-caption">
                  <span>{video.label}</span>
                  {video.detail && <strong>{video.detail}</strong>}
                </div>
              </article>
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.querySelector('#expert-coaches');
    if (!section) return;

    const videos = Array.from(section.querySelectorAll('video[data-src]'));

    const loadVideo = (video: Element) => {
      if (!(video instanceof HTMLVideoElement)) return;
      const src = video.dataset.src;
      if (!src || video.currentSrc) return;
      video.src = src;
      video.preload = 'metadata';
      video.load();
    };

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            loadVideo(entry.target);
            observer.unobserve(entry.target);
          });
        },
        { rootMargin: '640px 0px' }
      );

      videos.forEach((video) => observer.observe(video));
    } else {
      videos.forEach(loadVideo);
    }
  })();
</script>
