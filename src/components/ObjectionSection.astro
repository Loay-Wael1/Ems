---
import { siteContent, type Locale } from '../i18n/content';

interface Props {
  copy?: (typeof siteContent)[Locale]['proof'];
  locale?: Locale;
}

const { copy = siteContent.en.proof } = Astro.props;
const proofCards = copy.cards;
---

<section class="section-padding proof-section" id="why-ems" aria-labelledby="proof-title">
  <div class="container split-layout">
    <div class="section-head sticky-head reveal-on-scroll">
      <h2 id="proof-title" class="section-title">
        {copy.title}
      </h2>
      <p class="section-intro">
        {copy.intro}
      </p>
    </div>

    <div class="proof-grid">
      {
        proofCards.map((card, index) => (
          <article class="proof-card reveal-on-scroll" style={`--card-index:${index}`}>
            <span class="card-number">{String(index + 1).padStart(2, '0')}</span>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
