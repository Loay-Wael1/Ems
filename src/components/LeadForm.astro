---
import { siteContent, type Locale } from '../i18n/content';

interface Props {
  copy?: (typeof siteContent)[Locale]['leadForm'];
  locale?: Locale;
}

const { copy = siteContent.en.leadForm, locale = 'en' } = Astro.props;
const renderedAt = Date.now();
---

<div class="lead-shell">
  <div class="section-head lead-copy">
    <span class="lead-eyebrow">{copy.eyebrow}</span>
    <h2 id="final-cta-title" class="section-title">{copy.title}</h2>
    <p class="section-intro">
      {copy.intro}
    </p>

  </div>

  <div class="lead-form-card">
    <h3>{copy.cardTitle}</h3>
    <form class="lead-form" data-lead-form data-locale={locale} data-success-message={copy.success} data-error-message={copy.error} novalidate>
      <input type="text" name="lead_trap_field" tabindex="-1" autocomplete="new-password" class="lead-honeypot" aria-hidden="true" />
      <input type="hidden" name="renderedAt" value={renderedAt} />

      <div class="form-field">
        <label for="lead-name">{copy.labels.name}</label>
        <input id="lead-name" name="name" type="text" autocomplete="name" placeholder={copy.placeholders.name} maxlength="80" required />
      </div>

      <div class="form-field">
        <label for="lead-phone">{copy.labels.phone}</label>
        <input
          id="lead-phone"
          name="phone"
          type="tel"
          autocomplete="tel"
          inputmode="tel"
          placeholder={copy.placeholders.phone}
          maxlength="30"
          required
        />
      </div>

      <div class="form-field">
        <label for="lead-branch">{copy.labels.branch}</label>
        <select id="lead-branch" name="branch" required>
          <option value="">{copy.branchPlaceholder}</option>
          <option value="smouha">{copy.branches.smouha}</option>
          <option value="ganaklis">{copy.branches.ganaklis}</option>
        </select>
      </div>

      <p class="lead-privacy">
        {copy.privacy}
      </p>

      <button class="btn btn-primary btn-large lead-submit" type="submit" data-submit-label={copy.submit} data-loading-label={copy.loading}>
        {copy.submit}
      </button>

      <p class="lead-status" data-lead-status aria-live="polite"></p>
    </form>
  </div>
</div>

<script>
  (() => {
    const form = document.querySelector('[data-lead-form]');
    if (!(form instanceof HTMLFormElement)) return;

    const status = form.querySelector('[data-lead-status]');
    const submitButton = form.querySelector('.lead-submit');
    const successMessage = form.dataset.successMessage || 'Your request has been received. We will contact you shortly.';
    const errorMessage = form.dataset.errorMessage || 'Something went wrong. Please try again or message us on WhatsApp.';

    const setStatus = (message, type = '') => {
      if (!status) return;
      status.textContent = message;
      status.setAttribute('data-state', type);
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!form.reportValidity()) return;
      if (!(submitButton instanceof HTMLButtonElement)) return;

      submitButton.disabled = true;
      submitButton.textContent = submitButton.getAttribute('data-loading-label') || 'Sending request...';
      setStatus('', '');

      const data = new FormData(form);
      const params = new URLSearchParams(window.location.search);
      const payload = {
        name: data.get('name'),
        phone: data.get('phone'),
        branch: data.get('branch'),
        lead_trap_field: data.get('lead_trap_field'),
        renderedAt: Number(data.get('renderedAt')),
        submittedAt: Date.now(),
        page: window.location.pathname,
        locale: form.dataset.locale || 'en',
        utm_source: params.get('utm_source') || '',
        utm_medium: params.get('utm_medium') || '',
        utm_campaign: params.get('utm_campaign') || ''
      };

      try {
        const response = await fetch('/api/leads', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const result = await response.json().catch(() => ({ ok: false }));

        if (!response.ok || !result.ok) {
          throw new Error('lead_submit_failed');
        }

        form.reset();
        const timestamp = form.querySelector('input[name="renderedAt"]');
        if (timestamp instanceof HTMLInputElement) timestamp.value = String(Date.now());
        setStatus(successMessage, 'success');
      } catch {
        setStatus(errorMessage, 'error');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = submitButton.getAttribute('data-submit-label') || 'Request my trial session';
      }
    });
  })();
</script>
