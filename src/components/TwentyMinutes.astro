---
const whatsappUrl = 'https://wa.me/201124799978';
const points = ['Focused session', 'Coach guidance', 'Measured intensity', 'Clear goal'];
---

<section class="section-padding twenty-section" aria-labelledby="twenty-title">
  <div class="container twenty-grid">
    <div class="twenty-visual reveal-on-scroll" data-count-section>
      <div class="count-ring" aria-hidden="true"></div>
      <div class="timer-display">
        <span class="count-number" data-count-to="20">0</span>
        <small>minutes</small>
        <p>Full-body activation</p>
        <em>One focused coach-guided EMS session</em>
      </div>
    </div>

    <div class="twenty-copy reveal-on-scroll reveal-delay-1">
      <p class="eyebrow">THE 20-MINUTE DIFFERENCE</p>
      <h2 id="twenty-title" class="section-title">Less wasted time. More focused training.</h2>
      <p class="section-intro">
        A short session can still feel intense when the workout, EMS suit, and coaching are all
        calibrated around your body. The result is a smarter routine you can actually stay consistent with.
      </p>

      <div class="claim-pill">20 Min EMS = 2 Hours in Gym</div>
      <ul class="mini-points" aria-label="Session features">
        {points.map((point) => <li>{point}</li>)}
      </ul>

      <a class="btn btn-primary" href={whatsappUrl} target="_blank" rel="noreferrer">
        Book the 20-Min Trial
      </a>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.querySelector('[data-count-section]');
    const number = section?.querySelector('[data-count-to]');
    if (!section || !number) return;

    const target = Number(number.getAttribute('data-count-to')) || 20;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let hasRun = false;

    const setValue = (value) => {
      number.textContent = String(Math.round(value));
    };

    const animate = () => {
      if (hasRun) return;
      hasRun = true;

      if (reducedMotion) {
        setValue(target);
        return;
      }

      const duration = 1100;
      const start = performance.now();

      const tick = (now) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        setValue(target * eased);

        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          setValue(target);
        }
      };

      requestAnimationFrame(tick);
    };

    if (!('IntersectionObserver' in window)) {
      animate();
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          animate();
          observer.disconnect();
        }
      },
      { threshold: 0.45 }
    );

    observer.observe(section);
  })();
</script>
