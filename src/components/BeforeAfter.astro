---
import { siteContent, type Locale } from '../i18n/content';
import resultOne from '../../b&a/result-1.webp';
import resultTwo from '../../b&a/result-2.webp';
import resultThree from '../../b&a/result-3.webp';
import resultFour from '../../b&a/result-4.webp';
import resultFive from '../../b&a/result-5.webp';

interface Props {
  copy?: (typeof siteContent)[Locale]['beforeAfter'];
  locale?: Locale;
}

const { copy = siteContent.en.beforeAfter } = Astro.props;

const resultImages = [resultOne, resultTwo, resultThree, resultFour, resultFive];
const transformations = copy.transformations.map((item, index) => ({
  ...item,
  image: resultImages[index]
}));
---

<section class="section-padding before-after-section" id="results" aria-labelledby="results-title">
  <div class="container">
    <div class="section-head center reveal-on-scroll">
      <h2 id="results-title" class="section-title">{copy.title}</h2>
      <p class="section-intro">
        {copy.intro}
      </p>
    </div>

    <div class="transformation-track" aria-label={copy.trackAriaLabel}>
      {
        transformations.map((item, index) => (
          <article class="transformation-card reveal-on-scroll" style={`--card-index:${index}`}>
            <div class="transformation-image-wrap">
              <img
                src={item.image.src}
                width={item.image.width}
                height={item.image.height}
                alt={`${item.tag} ${copy.altSuffix}`}
                loading={index === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
            <div class="transformation-meta">
              <span class="chip">{item.tag}</span>
              <h3>{item.title}</h3>
            </div>
          </article>
        ))
      }
    </div>

    <p class="swipe-hint reveal-on-scroll">{copy.swipeHint}</p>

    <p class="results-disclaimer reveal-on-scroll">
      {copy.disclaimer}
    </p>
  </div>
</section>
