<div class="intro-panel" aria-hidden="true">
  <div class="intro-content">
    <div class="intro-logo-frame">
      <svg class="intro-orbit" viewBox="0 0 320 320" role="img" aria-label="">
        <circle cx="160" cy="160" r="118" pathLength="1" />
        <circle cx="160" cy="160" r="86" pathLength="1" />
        <path d="M26 162 C74 94, 116 230, 160 160 S246 94, 294 162" pathLength="1" />
      </svg>
      <span class="intro-signal" aria-hidden="true"></span>
      <img class="intro-logo" src="/logo-transparent.png" alt="" width="220" height="220" />
    </div>
    <p class="intro-eyebrow">Alexandria's 1st EMS Studio</p>
    <p class="intro-title">Train smarter in less time</p>
  </div>
</div>

<script>
  (() => {
    const html = document.documentElement;
    const panel = document.querySelector('.intro-panel');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!panel || !html.classList.contains('has-intro') || reducedMotion) {
      panel?.remove();
      html.classList.add('intro-done');
      html.classList.remove('has-intro');
      return;
    }

    window.setTimeout(() => {
      html.classList.add('intro-revealing');
    }, 620);

    window.setTimeout(() => {
      try {
        sessionStorage.setItem('easyfitIntroSeen', 'true');
      } catch (error) {
        /* Keep the reveal non-blocking if storage is unavailable. */
      }
      html.classList.remove('has-intro', 'intro-revealing');
      html.classList.add('intro-done');
      panel.remove();
    }, 1680);
  })();
</script>
