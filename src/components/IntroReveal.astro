---
---
<div class="intro-panel" id="pageReveal" aria-hidden="true">
  <div class="intro-content">
    <div class="intro-logo-frame">
      <!-- Clean, subtle dotted wave surrounding the logo -->
      <svg class="intro-pulse-wave" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="100" cy="100" r="85" stroke="rgba(255, 255, 255, 0.08)" stroke-width="1" stroke-dasharray="3 5" />
        <circle cx="100" cy="100" r="65" stroke="rgba(255, 255, 255, 0.05)" stroke-width="1.5" />
        <path d="M 30,100 Q 65,40 100,100 T 170,100" stroke="rgba(255, 255, 255, 0.12)" stroke-width="1" stroke-dasharray="2 3" />
      </svg>
      <!-- Original logo clean and untouched -->
      <img src="/logo-transparent.png" class="intro-logo" alt="Easy Fit Logo" width="120" height="120" />
    </div>
    
    <div class="intro-loader">
      <div class="intro-loader-bar"></div>
    </div>
  </div>
</div>

<script>
  const root = document.documentElement;
  const revealPanel = document.getElementById('pageReveal');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const markIntroSeen = () => {
    try {
      sessionStorage.setItem('easyfitIntroSeen', 'true');
    } catch (e) {
      // Privacy modes
    }
  };

  if (root.classList.contains('has-intro') && !reducedMotion && revealPanel) {
    setTimeout(() => {
      // Coordinated opposite movement: panel goes down, hero goes up
      root.classList.add('intro-revealing');
      
      setTimeout(() => {
        markIntroSeen();
        root.classList.remove('has-intro', 'intro-revealing');
        root.classList.add('intro-done');
        revealPanel.remove();
      }, 1300); // Panel transition matches global.css
    }, 600); // Brief hold for the loader progress bar
  } else {
    if (revealPanel) {
      revealPanel.remove();
    }
    root.classList.add('intro-done');
  }
</script>
