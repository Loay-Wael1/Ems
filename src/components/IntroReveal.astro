---
---
<div class="intro-panel" id="pageReveal" aria-hidden="true">
  <div class="intro-content">
    <div class="intro-logo-frame">
      <!-- Clean, subtle dotted wave surrounding the logo (static, no loops) -->
      <svg class="intro-pulse-wave" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="100" cy="100" r="85" stroke="rgba(6, 14, 29, 0.06)" stroke-width="1" stroke-dasharray="3 5" />
        <circle cx="100" cy="100" r="65" stroke="rgba(6, 14, 29, 0.04)" stroke-width="1.5" />
      </svg>
      <!-- Original logo clean and untouched -->
      <img src="/logo-transparent.png" class="intro-logo" alt="Easy Fit Logo" width="220" height="220" />
    </div>
    
    <!-- Subtitles under the logo -->
    <div class="intro-subtitle">Alexandria’s 1st EMS Studio</div>
    <div class="intro-arabic">تمرين أذكى في وقت أقل</div>
  </div>
</div>

<script>
  const root = document.documentElement;
  const revealPanel = document.getElementById('pageReveal');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const markIntroSeen = () => {
    try {
      sessionStorage.setItem('easyfitIntroSeen', 'true');
    } catch (e) {
      // Privacy modes
    }
  };

  if (root.classList.contains('has-intro') && !reducedMotion && revealPanel) {
    // Hold the logo long enough to read, then trigger the paired panel/page reveal.
    setTimeout(() => {
      root.classList.add('intro-revealing');
      
      setTimeout(() => {
        markIntroSeen();
        root.classList.remove('has-intro', 'intro-revealing');
        root.classList.add('intro-done');
        revealPanel.remove();
      }, 1600);
    }, 950);
  } else {
    if (revealPanel) {
      revealPanel.remove();
    }
    root.classList.add('intro-done');
  }
</script>
