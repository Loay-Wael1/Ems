<div class="intro-panel" aria-hidden="true">
  <div class="intro-content">
    <img class="intro-logo" src="/logo-transparent.png" alt="" width="180" height="180" />
  </div>
</div>

<script>
  (() => {
    const html = document.documentElement;
    const panel = document.querySelector('.intro-panel');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!panel || !html.classList.contains('has-intro') || reducedMotion) {
      panel?.remove();
      html.classList.add('intro-done');
      html.classList.remove('has-intro');
      return;
    }

    window.setTimeout(() => {
      html.classList.add('intro-revealing');
    }, 360);

    window.setTimeout(() => {
      try {
        sessionStorage.setItem('easyfitIntroSeen', 'true');
      } catch (error) {
        /* Keep the reveal non-blocking if storage is unavailable. */
      }
      html.classList.remove('has-intro', 'intro-revealing');
      html.classList.add('intro-done');
      panel.remove();
    }, 980);
  })();
</script>
