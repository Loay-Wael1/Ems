---
import '../styles/global.css';
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#F8FAFC" />
    <title>Easy Fit Leads Admin</title>
    <script is:inline>
      (() => {
        // Force admin dashboard to always use the stable light theme
        // to prevent public site dark mode bugs from affecting the admin UI.
        document.documentElement.dataset.theme = 'light';
        document.documentElement.style.colorScheme = 'light';
      })();
    </script>
    <style>
      .admin-page .admin-dashboard {
        width: min(100%, 1280px);
      }

      .admin-page .admin-toolbar-description {
        max-width: 58ch;
        color: #4b5563;
      }

      .admin-page .admin-summary-section {
        display: grid;
        gap: 0.75rem;
      }

      .admin-page .admin-summary-heading {
        color: #111a3a;
        font-size: 0.9rem;
        line-height: 1.3;
      }

      .admin-page .admin-summary-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
      }

      .admin-page .admin-summary-card {
        min-width: 0;
        display: grid;
        gap: 0.35rem;
        padding: 1rem;
        border: 1px solid rgba(17, 26, 58, 0.1);
        border-radius: 14px;
        background: #ffffff;
      }

      .admin-page .admin-summary-label {
        color: #5f6b7a;
        font-size: 0.76rem;
        font-weight: 800;
        text-transform: uppercase;
      }

      .admin-page .admin-summary-value {
        color: #111a3a;
        font-family: var(--font-display);
        font-size: clamp(1.65rem, 4vw, 2.2rem);
        font-weight: 900;
        line-height: 1;
      }

      .admin-page .admin-filters {
        grid-template-columns: 1fr;
      }

      .admin-page .admin-filter-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        align-items: center;
      }

      .admin-page .admin-filter-actions .btn {
        flex: 1 1 150px;
      }

      .admin-page .admin-table-wrap {
        max-height: min(68vh, 760px);
        overflow: auto;
      }

      .admin-page .admin-table {
        min-width: 1120px;
      }

      .admin-page .admin-table thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        box-shadow: 0 1px 0 rgba(17, 26, 58, 0.08);
      }

      .admin-page .admin-attribution {
        min-width: 150px;
        display: grid;
        justify-items: start;
        gap: 0.3rem;
      }

      .admin-page .admin-source-badge {
        display: inline-flex;
        align-items: center;
        min-height: 26px;
        padding: 0.24rem 0.55rem;
        border: 1px solid rgba(15, 118, 110, 0.18);
        border-radius: 999px;
        background: rgba(15, 118, 110, 0.1);
        color: #0f766e;
        font-size: 0.74rem;
        font-weight: 900;
      }

      .admin-page .admin-attribution-medium,
      .admin-page .admin-attribution-campaign,
      .admin-page .admin-attribution-empty {
        color: #5f6b7a;
        font-size: 0.78rem;
        line-height: 1.35;
        overflow-wrap: anywhere;
      }

      .admin-page .admin-attribution-campaign strong {
        color: #344054;
      }

      .admin-page .admin-attribution-empty {
        font-weight: 750;
      }

      .admin-page .admin-filters input:focus-visible,
      .admin-page .admin-filters select:focus-visible,
      .admin-page .admin-filter-actions .btn:focus-visible,
      .admin-page .admin-table button:focus-visible {
        outline: 2px solid #0f766e;
        outline-offset: 2px;
      }

      @media (min-width: 680px) {
        .admin-page .admin-summary-grid {
          grid-template-columns: repeat(4, minmax(0, 1fr));
        }

        .admin-page .admin-filters {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .admin-page .admin-filter-actions {
          grid-column: 1 / -1;
          justify-content: flex-end;
        }

        .admin-page .admin-filter-actions .btn {
          flex: 0 0 auto;
        }
      }

      @media (min-width: 1040px) {
        .admin-page .admin-filters {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }
      }

      @media (max-width: 430px) {
        .admin-page .admin-summary-card {
          padding: 0.85rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .admin-page .btn,
        .admin-page input,
        .admin-page select,
        .admin-page textarea {
          transition: none !important;
        }
      }
    </style>
  </head>
  <body class="admin-body">
    <main class="admin-page" id="main-content">
      <section class="admin-card admin-loading-card" data-auth-loading>
        <div class="admin-head">
          <img src="/logo-transparent.png" alt="" width="54" height="54" />
          <div>
            <h1>Leads Admin</h1>
            <p>Checking your admin session...</p>
          </div>
        </div>
        <p class="admin-status" data-auth-status aria-live="polite">Loading leads dashboard.</p>
      </section>

      <section class="admin-card" data-login-panel hidden>
        <div class="admin-head">
          <img src="/logo-transparent.png" alt="" width="54" height="54" />
          <div>
            <h1>Leads Admin</h1>
            <p>Sign in to manage Easy Fit Alexandria booking requests.</p>
          </div>
        </div>

        <form class="admin-login-form" data-login-form>
          <label for="admin-password">Password</label>
          <input id="admin-password" name="password" type="password" autocomplete="current-password" required />
          <button class="btn btn-primary btn-large" type="submit">Login</button>
          <p class="admin-status" data-login-status aria-live="polite"></p>
        </form>
      </section>

      <section class="admin-dashboard admin-card" data-dashboard hidden>
        <div class="admin-toolbar">
          <div class="admin-toolbar-brand">
            <img src="/logo-transparent.png" alt="" width="48" height="48" />
            <div>
              <h1>Lead Dashboard</h1>
              <p class="admin-toolbar-description">Recent booking requests with campaign attribution and follow-up status.</p>
              <p data-admin-summary>Showing 0 leads</p>
              <p class="admin-meta" data-last-updated aria-live="polite">Last updated: never</p>
            </div>
          </div>
          <div class="admin-actions">
            <button class="btn btn-primary" type="button" data-save-all disabled>Save All</button>
            <a class="btn btn-ghost" href="/api/admin/leads/export">Export All CSV</a>
            <button class="btn btn-primary" type="button" data-logout>Logout</button>
          </div>
        </div>

        <section class="admin-summary-section" aria-labelledby="admin-summary-heading">
          <h2 class="admin-summary-heading" id="admin-summary-heading">Current retained leads</h2>
          <div class="admin-summary-grid">
            <article class="admin-summary-card" aria-label="Total retained leads">
              <span class="admin-summary-label">Total Leads</span>
              <strong class="admin-summary-value" data-summary-total>0</strong>
            </article>
            <article class="admin-summary-card" aria-label="New retained leads">
              <span class="admin-summary-label">New</span>
              <strong class="admin-summary-value" data-summary-new>0</strong>
            </article>
            <article class="admin-summary-card" aria-label="Arrived retained leads">
              <span class="admin-summary-label">Arrived</span>
              <strong class="admin-summary-value" data-summary-arrived>0</strong>
            </article>
            <article class="admin-summary-card" aria-label="Booked retained leads">
              <span class="admin-summary-label">Booked</span>
              <strong class="admin-summary-value" data-summary-booked>0</strong>
            </article>
          </div>
        </section>

        <form class="admin-filters" data-filter-form>
          <label>
            Branch
            <select name="branch">
              <option value="">All</option>
              <option value="smouha">Smouha</option>
              <option value="ganaklis">Ganaklis</option>
            </select>
          </label>
          <label>
            Status
            <select name="status">
              <option value="">All</option>
              <option value="new">New</option>
              <option value="arrived">Arrived</option>
              <option value="booked">Booked</option>
            </select>
          </label>
          <label>
            Search
            <input name="search" type="search" placeholder="Name or phone" autocomplete="off" />
          </label>
          <label>
            Source
            <input name="source" type="text" list="admin-source-options" placeholder="e.g. facebook" autocomplete="off" maxlength="120" />
          </label>
          <label>
            Medium
            <input name="medium" type="text" list="admin-medium-options" placeholder="e.g. paid_social" autocomplete="off" maxlength="120" />
          </label>
          <label>
            Campaign
            <input name="campaign" type="text" list="admin-campaign-options" placeholder="Campaign contains..." autocomplete="off" maxlength="120" />
          </label>
          <datalist id="admin-source-options" data-source-options></datalist>
          <datalist id="admin-medium-options" data-medium-options></datalist>
          <datalist id="admin-campaign-options" data-campaign-options></datalist>
          <div class="admin-filter-actions">
            <button class="btn btn-primary" type="submit">Apply Filters</button>
            <button class="btn btn-ghost" type="button" data-clear-filters>Clear Filters</button>
          </div>
        </form>

        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th scope="col">Date</th>
                <th scope="col">Name</th>
                <th scope="col">Phone</th>
                <th scope="col">Branch</th>
                <th scope="col">Attribution</th>
                <th scope="col">Status</th>
                <th scope="col">Notes</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody data-leads-body>
              <tr>
                <td colspan="8">No leads yet.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="admin-status" data-admin-status aria-live="polite"></p>
      </section>
    </main>

    <script>
      (() => {
        const POLL_INTERVAL_MS = 12000;
        const STATUSES = ['new', 'arrived', 'booked'];
        const loginPanel = document.querySelector('[data-login-panel]');
        const dashboard = document.querySelector('[data-dashboard]');
        const authLoading = document.querySelector('[data-auth-loading]');
        const loginForm = document.querySelector('[data-login-form]');
        const filterForm = document.querySelector('[data-filter-form]');
        const loginStatus = document.querySelector('[data-login-status]');
        const authStatus = document.querySelector('[data-auth-status]');
        const adminStatus = document.querySelector('[data-admin-status]');
        const summary = document.querySelector('[data-admin-summary]');
        const lastUpdated = document.querySelector('[data-last-updated]');
        const summaryTotal = document.querySelector('[data-summary-total]');
        const summaryNew = document.querySelector('[data-summary-new]');
        const summaryArrived = document.querySelector('[data-summary-arrived]');
        const summaryBooked = document.querySelector('[data-summary-booked]');
        const sourceOptions = document.querySelector('[data-source-options]');
        const mediumOptions = document.querySelector('[data-medium-options]');
        const campaignOptions = document.querySelector('[data-campaign-options]');
        const tbody = document.querySelector('[data-leads-body]');
        const logoutButton = document.querySelector('[data-logout]');
        const saveAllButton = document.querySelector('[data-save-all]');
        const clearFiltersButton = document.querySelector('[data-clear-filters]');

        const leadBaseline = new Map();
        const dirtyRows = new Map();
        const savingRows = new Set();
        let pollTimer = 0;
        let isLoadingLeads = false;
        let isSavingAll = false;

        const setText = (node, text, state = '') => {
          if (!node) return;
          node.textContent = text;
          if (state) {
            node.dataset.state = state;
          } else {
            delete node.dataset.state;
          }
        };

        const setView = (view) => {
          authLoading.hidden = view !== 'loading';
          loginPanel.hidden = view !== 'login';
          dashboard.hidden = view !== 'dashboard';

          if (view === 'dashboard') {
            startPolling();
          } else {
            stopPolling();
          }
        };

        const showDashboard = () => {
          setView('dashboard');
        };

        const showLogin = (message = '') => {
          setView('login');
          setText(loginStatus, message, message ? 'error' : '');
        };

        const paramsFromFilters = () => {
          const data = new FormData(filterForm);
          const params = new URLSearchParams();
          ['branch', 'status', 'search', 'source', 'medium', 'campaign'].forEach((key) => {
            const value = String(data.get(key) || '').trim();
            if (value) params.set(key, value);
          });
          return params;
        };

        const renderSummary = (value = {}) => {
          setText(summaryTotal, formatCount(value.total));
          setText(summaryNew, formatCount(value.new));
          setText(summaryArrived, formatCount(value.arrived));
          setText(summaryBooked, formatCount(value.booked));
        };

        const replaceDatalistOptions = (datalist, values) => {
          if (!datalist) return;
          const fragment = document.createDocumentFragment();
          const seen = new Set();

          (Array.isArray(values) ? values : []).forEach((value) => {
            const text = cleanAttributionValue(value);
            const key = text.toLowerCase();
            if (!text || seen.has(key)) return;
            seen.add(key);
            const option = document.createElement('option');
            option.value = text;
            fragment.append(option);
          });

          datalist.replaceChildren(fragment);
        };

        const renderFilterOptions = (options = {}) => {
          replaceDatalistOptions(sourceOptions, options.sources);
          replaceDatalistOptions(mediumOptions, options.media);
          replaceDatalistOptions(campaignOptions, options.campaigns);
        };

        const updateLastUpdated = () => {
          setText(lastUpdated, `Last updated: ${new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`);
        };

        const updateSaveAllState = () => {
          const visibleLeadCount = tbody.querySelectorAll('[data-lead-id]').length;
          if (saveAllButton) {
            saveAllButton.disabled = visibleLeadCount === 0 || isSavingAll || savingRows.size > 0;
            saveAllButton.textContent = isSavingAll ? 'Saving...' : 'Save All';
          }
          tbody.querySelectorAll('[data-save]').forEach((button) => {
            const row = button.closest('[data-lead-id]');
            const leadId = row?.dataset.leadId || '';
            button.disabled = isSavingAll || savingRows.has(leadId);
            button.textContent = savingRows.has(leadId) ? 'Saving...' : 'Save';
          });
        };

        const loadLeads = async ({ initial = false, silent = false } = {}) => {
          if (isLoadingLeads) return;

          isLoadingLeads = true;
          if (!silent) setText(adminStatus, initial ? '' : 'Refreshing leads...');

          try {
            const params = paramsFromFilters();
            const query = params.toString();
            const response = await fetch(`/api/admin/leads${query ? `?${query}` : ''}`, {
              credentials: 'same-origin'
            });

            if (response.status === 401) {
              dirtyRows.clear();
              leadBaseline.clear();
              setText(adminStatus, '');
              showLogin();
              return;
            }

            const result = await response.json().catch(() => ({ ok: false }));
            if (!response.ok || !result.ok) throw new Error('load_failed');

            renderSummary(result.summary || {});
            renderFilterOptions(result.filterOptions || {});
            renderLeads(result.leads || []);
            updateLastUpdated();
            if (!silent) setText(adminStatus, result.leads?.length ? 'Leads loaded.' : 'No leads yet.', 'success');
            showDashboard();
          } catch {
            if (initial) {
              setView('login');
              setText(loginStatus, 'Could not verify your session. Please sign in again.', 'error');
              setText(authStatus, 'Could not load the admin dashboard.', 'error');
            } else {
              setText(adminStatus, 'Could not refresh leads. Please try again.', 'error');
            }
          } finally {
            isLoadingLeads = false;
          }
        };

        const startPolling = () => {
          stopPolling();
          if (document.hidden) return;

          pollTimer = window.setInterval(() => {
            if (!document.hidden && !isSavingAll) {
              loadLeads({ silent: true }).catch(() => {});
            }
          }, POLL_INTERVAL_MS);
        };

        const stopPolling = () => {
          if (pollTimer) {
            window.clearInterval(pollTimer);
            pollTimer = 0;
          }
        };

        const refreshVisibleDashboard = () => {
          if (!dashboard.hidden && !document.hidden && !isSavingAll) {
            loadLeads({ silent: true }).catch(() => {});
          }
        };

        const getRowValues = (row) => ({
          status: row.querySelector('[data-status]')?.value || 'new',
          notes: row.querySelector('[data-notes]')?.value || ''
        });

        const setRowDirtyState = (row, isDirty) => {
          row.classList.toggle('is-dirty', isDirty);
          const saveButton = row.querySelector('[data-save]');
          if (saveButton) {
            saveButton.textContent = savingRows.has(row.dataset.leadId) ? 'Saving...' : 'Save';
            saveButton.setAttribute('aria-label', 'Save lead changes');
          }
        };

        const syncDirtyState = (row) => {
          const leadId = row.dataset.leadId;
          const baseline = leadBaseline.get(leadId);
          if (!baseline) return;

          const current = getRowValues(row);
          const isDirty = current.status !== baseline.status || current.notes !== baseline.notes;

          if (isDirty) {
            dirtyRows.set(leadId, current);
          } else {
            dirtyRows.delete(leadId);
          }

          setRowDirtyState(row, isDirty);
          updateSaveAllState();
        };

        const saveLead = async (leadId, values) => {
          const response = await fetch(`/api/admin/leads/${encodeURIComponent(leadId)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(values),
            credentials: 'same-origin'
          });
          const result = await response.json().catch(() => ({ ok: false }));
          if (!response.ok || !result.ok) throw new Error('save_failed');
          return result;
        };

        const markSaved = (leadId, values) => {
          leadBaseline.set(leadId, { ...values });
          dirtyRows.delete(leadId);
          const row = tbody.querySelector(`[data-lead-id="${cssEscape(leadId)}"]`);
          if (row) setRowDirtyState(row, false);
          updateSaveAllState();
        };

        const saveOneRow = async (row, button) => {
          if (isSavingAll) return;
          const leadId = row.dataset.leadId;
          const values = getRowValues(row);

          savingRows.add(leadId);
          updateSaveAllState();
          setText(adminStatus, '');

          try {
            await saveLead(leadId, values);
            markSaved(leadId, values);
            setText(adminStatus, 'Lead updated.', 'success');
          } catch {
            setText(adminStatus, 'Could not update lead.', 'error');
          } finally {
            savingRows.delete(leadId);
            updateSaveAllState();
          }
        };

        const saveAllRows = async () => {
          const rows = [...tbody.querySelectorAll('[data-lead-id]')];
          const entries = rows.map((row) => [row.dataset.leadId, getRowValues(row)]);
          if (!entries.length || isSavingAll || savingRows.size > 0) return;

          isSavingAll = true;
          updateSaveAllState();
          setText(adminStatus, `Saving ${entries.length} lead${entries.length === 1 ? '' : 's'}...`);

          const results = await Promise.allSettled(entries.map(([leadId, values]) => saveLead(leadId, values)));
          let savedCount = 0;
          let failedCount = 0;

          results.forEach((result, index) => {
            const [leadId, values] = entries[index];
            if (result.status === 'fulfilled') {
              savedCount += 1;
              markSaved(leadId, values);
            } else {
              failedCount += 1;
            }
          });

          isSavingAll = false;
          updateSaveAllState();

          if (failedCount) {
            setText(adminStatus, `${savedCount} saved. ${failedCount} failed. Please retry the remaining changes.`, 'error');
            return;
          }

          setText(adminStatus, `${savedCount} lead${savedCount === 1 ? '' : 's'} saved.`, 'success');
          loadLeads({ silent: true }).catch(() => {});
        };

        const renderLeads = (leads) => {
          const visibleIds = new Set(leads.map((lead) => String(lead.id)));
          [...dirtyRows.keys()].forEach((leadId) => {
            if (!visibleIds.has(leadId)) dirtyRows.delete(leadId);
          });

          setText(summary, `Showing ${leads.length} lead${leads.length === 1 ? '' : 's'}`);
          if (!leads.length) {
            leadBaseline.clear();
            tbody.innerHTML = '<tr><td colspan="8">No leads match the current filters.</td></tr>';
            updateSaveAllState();
            return;
          }

          tbody.innerHTML = leads
            .map((lead) => {
              const leadId = String(lead.id);
              const baseline = {
                status: normalizeLeadStatus(lead.status),
                notes: lead.notes || ''
              };
              const dirty = dirtyRows.get(leadId);
              const current = dirty || baseline;
              const isDirty = Boolean(dirty);

              leadBaseline.set(leadId, baseline);

              return `
                <tr data-lead-id="${escapeHtml(leadId)}" class="${isDirty ? 'is-dirty' : ''}">
                  <td>${escapeHtml(formatDate(lead.created_at))}</td>
                  <td>
                    <strong>${escapeHtml(lead.name)}</strong>
                  </td>
                  <td><a href="tel:${escapeHtml(lead.phone)}">${escapeHtml(lead.phone)}</a></td>
                  <td>${escapeHtml(formatBranch(lead.branch))}</td>
                  <td>${renderAttribution(lead)}</td>
                  <td>
                    <span class="admin-status-pill" data-status-value="${escapeHtml(current.status)}">${escapeHtml(formatStatus(current.status))}</span>
                    <select data-status aria-label="Lead status">
                      ${STATUSES.map((status) => `<option value="${status}" ${current.status === status ? 'selected' : ''}>${formatStatus(status)}</option>`).join('')}
                    </select>
                  </td>
                  <td><textarea data-notes rows="2" aria-label="Lead notes">${escapeHtml(current.notes)}</textarea></td>
                  <td><button class="btn btn-primary" type="button" data-save aria-label="Save lead changes">Save</button></td>
                </tr>
              `;
            })
            .join('');

          tbody.querySelectorAll('[data-lead-id]').forEach((row) => {
            setRowDirtyState(row, dirtyRows.has(row.dataset.leadId));
          });
          updateSaveAllState();
        };

        loginForm.addEventListener('submit', async (event) => {
          event.preventDefault();
          setText(loginStatus, '');
          const password = String(new FormData(loginForm).get('password') || '');

          try {
            const response = await fetch('/api/admin/login', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ password }),
              credentials: 'same-origin'
            });
            const result = await response.json().catch(() => ({ ok: false }));
            if (!response.ok || !result.ok) throw new Error('login_failed');
            loginForm.reset();
            await loadLeads();
          } catch {
            setText(loginStatus, 'Login failed.', 'error');
          }
        });

        filterForm.addEventListener('submit', async (event) => {
          event.preventDefault();
          setText(adminStatus, '');
          await loadLeads();
        });

        filterForm.addEventListener('change', () => {
          stopPolling();
          startPolling();
        });

        clearFiltersButton?.addEventListener('click', async () => {
          filterForm.reset();
          setText(adminStatus, 'Refreshing leads...');
          await loadLeads();
        });

        tbody.addEventListener('input', (event) => {
          const target = event.target;
          if (!(target instanceof Element) || !target.matches('[data-status], [data-notes]')) return;
          const row = target.closest('[data-lead-id]');
          if (!row) return;
          syncDirtyState(row);
        });

        tbody.addEventListener('change', (event) => {
          const target = event.target;
          if (!(target instanceof Element) || !target.matches('[data-status]')) return;
          const row = target.closest('[data-lead-id]');
          if (!row) return;
          const pill = row.querySelector('.admin-status-pill');
          if (pill) {
            pill.dataset.statusValue = target.value;
            pill.textContent = formatStatus(target.value);
          }
          syncDirtyState(row);
        });

        tbody.addEventListener('click', async (event) => {
          const button = event.target.closest('[data-save]');
          if (!button) return;

          const row = button.closest('[data-lead-id]');
          if (!row) return;
          await saveOneRow(row, button);
        });

        saveAllButton?.addEventListener('click', saveAllRows);

        logoutButton.addEventListener('click', async () => {
          stopPolling();
          await fetch('/api/admin/logout', { method: 'POST', credentials: 'same-origin' }).catch(() => {});
          dirtyRows.clear();
          leadBaseline.clear();
          updateSaveAllState();
          showLogin();
        });

        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            stopPolling();
            return;
          }

          startPolling();
          refreshVisibleDashboard();
        });

        loadLeads({ initial: true });

        function formatDate(value) {
          return value ? new Date(value).toLocaleString() : '';
        }

        function formatBranch(value) {
          return value === 'ganaklis' ? 'Ganaklis' : 'Smouha';
        }

        function formatStatus(value) {
          return value.charAt(0).toUpperCase() + value.slice(1);
        }

        function formatCount(value) {
          const count = Number(value || 0);
          return String(Number.isFinite(count) && count > 0 ? Math.floor(count) : 0);
        }

        function cleanAttributionValue(value) {
          return String(value ?? '')
            .replace(/[\u0000-\u001F\u007F-\u009F]/g, ' ')
            .replace(/\s+/g, ' ')
            .trim()
            .slice(0, 120);
        }

        function humanizeAttributionValue(value) {
          return cleanAttributionValue(value)
            .replace(/[_-]+/g, ' ')
            .replace(/\b\w/g, (character) => character.toUpperCase());
        }

        function formatMedium(value) {
          const medium = cleanAttributionValue(value);
          const knownMedia = {
            paid_social: 'Paid Social',
            organic_social: 'Organic Social',
            organic_local: 'Organic Local',
            paid_video: 'Paid Video',
            cpc: 'CPC',
            messaging: 'Messaging'
          };
          return knownMedia[medium.toLowerCase()] || humanizeAttributionValue(medium);
        }

        function renderAttribution(lead) {
          const source = cleanAttributionValue(lead.utm_source);
          const medium = cleanAttributionValue(lead.utm_medium);
          const campaign = cleanAttributionValue(lead.utm_campaign);

          if (!source && !medium && !campaign) {
            return '<span class="admin-attribution-empty">Direct / Unknown</span>';
          }

          const details = [];
          if (source) {
            details.push(`<span class="admin-source-badge">${escapeHtml(humanizeAttributionValue(source))}</span>`);
          }
          if (medium) {
            details.push(`<span class="admin-attribution-medium">${escapeHtml(formatMedium(medium))}</span>`);
          }
          if (campaign) {
            details.push(`<span class="admin-attribution-campaign"><strong>Campaign:</strong> ${escapeHtml(campaign)}</span>`);
          }

          return `<div class="admin-attribution">${details.join('')}</div>`;
        }

        function normalizeLeadStatus(value) {
          if (value === 'arrived' || value === 'booked' || value === 'new') return value;
          return 'new';
        }

        function cssEscape(value) {
          if (window.CSS?.escape) return window.CSS.escape(value);
          return String(value).replace(/"/g, '\\"');
        }

        function escapeHtml(value) {
          return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
        }
      })();
    </script>
  </body>
</html>
